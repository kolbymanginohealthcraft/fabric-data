	column TableDisch
		isHidden
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 2c3100db-9a41-4855-8c11-78cc0fa524b9
		summarizeBy: average
		isNameInferred
		sourceColumn: [TableDisch]

		annotation SummarizationSetBy = User

	column EvalNEW = ```
			
			// IF(
			//     RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility","(b) Section GG Self Care"} && 
			//     OutcomeSummary[Criteria Start] IN {"ANA","Missing"},0,
			//     OutcomeSummary[TableEval]
			// )
			
			
			IF(
			    RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility","(b) Section GG Self Care"} &&
			    ISBLANK(OutcomeSummary[StartScoreValues]) || 
			    (
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15102") || //score value of 07
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15103") || //score value of 08
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15104") || //score value of 10
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15105") //score value of 88
			    ),
			    0,
			    OutcomeSummary[TableEval]
			)
			```
		lineageTag: 5e224f89-c0b4-46bb-9439-059c32eec06c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Status =
			
			IF(
			    ISBLANK(OutcomeSummary[EvalNEW])=FALSE() && ISBLANK(OutcomeSummary[TableDisch])=FALSE() && OutcomeSummary[EvalNEW]<>1 && OutcomeSummary[IsCrosswalked]=TRUE(),
			    "Included",
			    "Excluded"
			)
		lineageTag: 8b825428-12dc-4d64-82c7-1783f18082c1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EvalMethod
		lineageTag: c5030e96-8289-44c4-b35d-0f5a2bbf7785
		summarizeBy: none
		isNameInferred
		sourceColumn: [EvalMethod]

		annotation SummarizationSetBy = Automatic

	column Story =
			
			SWITCH(
			    TRUE(),
			    OutcomeSummary[Status]="Included","Included",
			    OutcomeSummary[IsCrosswalked]=FALSE(),"Not Crosswalked",
			    OutcomeSummary[Criteria Start]="Independent","Excluded: Started Independent",
			    "Excluded: Other"
			)
		lineageTag: 849d9dde-e842-47b7-9104-92ba259a08c8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Criteria Start' = ```
			
			// SWITCH(
			//     TRUE(),
			//     OutcomeSummary[IsCrosswalked]=FALSE(),"Not Crosswalked",
			//     OutcomeSummary[TableEval]=1,"Independent",
			//     ISBLANK(OutcomeSummary[StartScoreValues]),"Missing",
			//     NOT(ISBLANK(OutcomeSummary[TableEval])),"Valid",
			//     RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility", "(b) Section GG Self Care"} && 
			//     (
			//         CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15102") || //score value of 07
			//         CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15103") || //score value of 08
			//         CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15104") || //score value of 10
			//         CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15105") //score value of 88
			//     ),"ANA",
			//     "Invalid"
			// )
			
			SWITCH(
			    TRUE(),
			    OutcomeSummary[IsCrosswalked]=FALSE(),"Not Crosswalked",
			    OutcomeSummary[TableEval]=1,"Independent",
			    ISBLANK(OutcomeSummary[StartScoreValues]),"Missing",
			    NOT(ISBLANK(OutcomeSummary[EvalNEW])),"Valid",
			    "Invalid"
			)
			```
		lineageTag: b01f2f59-e5d9-4344-8eda-25fcb24768db
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Criteria End' = ```
			
			// SWITCH(
			//     TRUE(),
			//     OutcomeSummary[IsCrosswalked]=FALSE(),"Not Crosswalked",
			//     ISBLANK(OutcomeSummary[EndScoreValues]),"Missing",
			//     NOT(ISBLANK(OutcomeSummary[TableDisch])),"Valid",
			//     RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility", "(b) Section GG Self Care"} && 
			//         (
			//             CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15102") || //score value of 07
			//             CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15103") || //score value of 08
			//             CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15104") || //score value of 10
			//             CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15105") //score value of 88
			//         ),"ANA",
			//     "Invalid"
			// )
			
			SWITCH(
			    TRUE(),
			    OutcomeSummary[IsCrosswalked]=FALSE(),"Not Crosswalked",
			    ISBLANK(OutcomeSummary[EndScoreValues]),"Missing",
			    NOT(ISBLANK(OutcomeSummary[TableDisch])),"Valid",
			    // RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility", "(b) Section GG Self Care"} && 
			    //     (
			    //         CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15102") || //score value of 07
			    //         CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15103") || //score value of 08
			    //         CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15104") || //score value of 10
			    //         CONTAINSSTRING(OutcomeSummary[EndScoreValues],"15105") //score value of 88
			    //     ),"ANA",
			    "Invalid"
			)
			```
		lineageTag: 0f5848ba-01d7-46d4-853c-5b5c7c04fc1d

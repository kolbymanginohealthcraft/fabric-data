	measure 'Top Diagnosis Category per Range' = ```
			
			
			VAR CurrentCategory = SELECTEDVALUE(StayCases[Range: Minutes per Week])
			VAR DiagnosisTable = 
			    FILTER(
			        DX_Cases,
			        RELATED(StayCases[Range: Minutes per Week]) = CurrentCategory
			    )
			VAR TopGroup = 
			    TOPN(
			        1,
			        SUMMARIZE(
			            DiagnosisTable,
			            DX_Cases[L2],
			            "CaseCount", [Total Cases PM Dx]
			        ),
			        [CaseCount], DESC,
			        DX_Cases[L2], ASC
			    )
			RETURN
			    MAXX(TopGroup, DX_Cases[L2])
			```
		lineageTag: ddef7590-2e21-49c8-be0d-4d090d0ae0aa

		annotation PBI_FormatHint = {"isGeneralNumber":true}


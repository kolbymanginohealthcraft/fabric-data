			//     "Mixed"
			// )
			
			var EDD_count = CALCULATE(COUNTROWS(DISTINCT(EDD[Label])))
			return
			SWITCH(
			    EDD_count,
			    BLANK(),"None Listed", // too many previously counted in mixed
			    0,BLANK(),
			    1,CALCULATE(CONCATENATEX(DISTINCT(EDD[Label]),EDD[Label],", ",EDD[Label],ASC)),

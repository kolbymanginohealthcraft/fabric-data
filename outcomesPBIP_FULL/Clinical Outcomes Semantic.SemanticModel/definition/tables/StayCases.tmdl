	measure 'Avg Number of Disciplines' =
			
			DIVIDE(
			    SUMX(
			        StayCases,
			        [Total Disciplines Unique]
			    ),
			    CALCULATE(
			        [Total Cases],
			        FILTER(
			            StayCases,
			            [Total Disciplines Unique]>0
			        )
			    )
			)
		formatString: 0.00

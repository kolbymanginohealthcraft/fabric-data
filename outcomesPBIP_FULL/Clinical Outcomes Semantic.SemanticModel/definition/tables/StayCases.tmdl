	measure 'DX Label' =
			
			// var fulllist = SUMMARIZE(FILTER(DX_Cases,DX_Cases[Type]="Primary"),DX_Cases[L4])
			// RETURN
			// CONCATENATEX(
			//     fulllist,
			//     DX_Cases[L4],
			//     ", ",
			//     DX_Cases[L4]
			// )
			
			CONCATENATEX(
			    CALCULATETABLE(
			        DISTINCT(DX_Cases),
			        DX_Cases[PatientCase_ID]=SELECTEDVALUE(StayCases[PatientCase_ID]),
			        DX_Cases[Type]="Primary",
			        ALL(DX_Cases[L4]),
			        ALL(DX_Cases[L3]),
			        ALL(DX_Cases[L2]),
			        ALL(DX_Cases[L1])
			    ),
			    DX_Cases[L4],
			    ", ",
			    DX_Cases[L4],
			    ASC
			)
		lineageTag: f8da997b-c6bb-4950-84c4-6e6140c5693e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gait Speed Skip Rate' = ```
			
			// var numerator = 
			// CALCULATE(
			//     [Total Cases],
			//     StayCases[Admit Level: Walk 10 ft]>=.85,
			//     ISBLANK(StayCases[Admit Level: Gait Speed])
			// )
			// var denominator = 
			// CALCULATE(
			//     [Total Cases],
			//     StayCases[Admit Level: Walk 10 ft]>=.85
			// )
			// return DIVIDE(numerator,denominator)
			
			
			var numerator = 
			CALCULATE(
			    [Total Tracks],
			    CaseTracks[Admit Level: Walk 10 ft]>=.85,
			    ISBLANK(CaseTracks[Admit Level: Gait Speed])
			)
			var denominator = 
			CALCULATE(
			    [Total Tracks],
			    CaseTracks[Admit Level: Walk 10 ft]>=.85
			)
			return DIVIDE(numerator,denominator)
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 41ba6168-215f-457b-84ef-27b26b51b722


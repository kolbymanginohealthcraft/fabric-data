	measure 'Average Diagnosis Weight' =
			
			// AVERAGEX(
			//     VALUES(StayCases[PatientCase_ID]),
			//     // COUNTROWS(RELATEDTABLE(DX_Cases))
			//     SUMX(Weights,Weights[Weight])
			// )
			
			// AVERAGEX(
			//     VALUES(StayCases[PatientCase_ID]),
			//     SUMX(RELATEDTABLE(DX_Cases),SUMX(RELATEDTABLE(Weights),Weights[Weight]))
			// )
			
			// AVERAGEX(
			//     VALUES(StayCases[PatientCase_ID]),
			//     SUM(DX_Cases[Weight])
			// )
			
			AVERAGEX(
			    VALUES(StayCases[PatientCase_ID]),
			    SUMX(
			        FILTER(
			            DISTINCT(
			                SELECTCOLUMNS(
			                    RELATEDTABLE(DX_Cases),
			                    "ICD", DX_Cases[ICD],
			                    "Weight",RELATED(Weights[Weight])
			                )
			            ),
			            NOT ISBLANK([Weight])
			        ),
			        [Weight]
			    )
			)
		formatString: 0.00
		lineageTag: 1df0ac62-13e5-49fa-a4f5-571582d397bb


	column 'Payer Categorization' = ```
			
			// IF(
			//     COUNTROWS(RELATEDTABLE(vw_PatientPayers))=1,
			//     MINX(RELATEDTABLE(vw_PatientPayers),vw_PatientPayers[Payer Group]),
			//     "(8) Multiple Payers"
			// )
			
			VAR RelatedRows =
			    RELATEDTABLE(vw_PatientPayers)
			VAR DistinctGroups =
			    SUMMARIZE(RelatedRows, vw_PatientPayers[Payer Group])
			RETURN
			IF(
			    COUNTROWS(DistinctGroups) = 1,
			    MAXX(DistinctGroups, vw_PatientPayers[Payer Group]),
			    "(8) Multiple Payers"
			)
			
			```
		displayFolder: Cohort Selection
		lineageTag: d0cbab09-f8ef-4783-b638-ad7663d844dc
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Age Range' =
			
			SWITCH(
			    TRUE(),
			    ISBLANK([Avg Age]),"UNK",
			    [Avg Age]<18,"17U",
			    [Avg Age]<50,"18-49",
			    [Avg Age]<65,"50-64",
			    [Avg Age]<70,"65-69",
			    [Avg Age]<75,"70-74",
			    [Avg Age]<80,"75-79",
			    [Avg Age]<85,"80-84",
			    [Avg Age]<90,"85-89",
			    [Avg Age]<95,"90-94",
			    "95+"
			)
		displayFolder: Cohort Selection
		lineageTag: 60d8c7ba-04d6-4075-a262-3d18c04dd6fd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Disc Inv' =
			
			var VisitsPT = IF(CALCULATE([Total Visits],Disciplines[Discipline]="PT")>0,"PT")
			var VisitsOT = IF(CALCULATE([Total Visits],Disciplines[Discipline]="OT")>0,"OT")
			var VisitsST = IF(CALCULATE([Total Visits],Disciplines[Discipline]="ST")>0,"ST")
			var ValuesTable = FILTER({VisitsPT, VisitsOT, VisitsST}, NOT(ISBLANK([Value])))
			var ValuesList = CONCATENATEX(ValuesTable,[Value],"/")
			return ValuesList
		displayFolder: Buckets
		lineageTag: d28cfdbe-79a7-4089-8275-20e7c91a3736
		summarizeBy: none

		annotation SummarizationSetBy = Automatic


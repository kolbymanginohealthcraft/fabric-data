	measure 'EDD % Community Delta Image' =
			
			// var metric = [EDD % Community Delta]
			// return
			// IF([Report Scope]="Filtered",
			// IF(metric=0,BLANK(),
			// IF(metric>0,FORMAT([Patient Acuity Delta Image Higher],""),
			// IF(metric<0,FORMAT([Patient Acuity Delta Image Lower],"")
			// ))))
			
			
			var metric = [EDD % Community Delta]
			return
			IF([Report Scope]="Filtered",
			IF(metric=0,BLANK(),
			IF(metric>0,FORMAT(SUBSTITUTE([Patient Acuity Delta Image Higher],"#9EB4C3","#7FBC42"),""),
			IF(metric<0,FORMAT(SUBSTITUTE([Patient Acuity Delta Image Lower],"#9EB4C3","#D64550"),"")
			))))
		lineageTag: 072eb4a5-e007-4c17-a58c-248313b55cd4
		dataCategory: ImageUrl


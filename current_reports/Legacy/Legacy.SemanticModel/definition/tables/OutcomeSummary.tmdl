	column TxTrack_ID
		formatString: 0
		lineageTag: c8ec11e2-a332-4da6-b705-1010d4a8eb39
		summarizeBy: none
		isNameInferred
		sourceColumn: CaseTracks[TxTrack_ID]

		annotation SummarizationSetBy = Automatic

	column IsCrosswalked = ISBLANK(RELATED(Dictionary[LibraryItem_ID]))=FALSE()
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: fdb3af04-85fd-4d39-af73-f2ff9c572b2f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition OutcomeSummary = calculated
		mode: import
		source =
				
				SUMMARIZE(
				    Assessments,
				    StayCases[PatientCase_ID],CaseTracks[TxTrack_ID],Assessments[LibraryItem_ID],
				    "TableEval",CALCULATE(AVERAGE('Outcomes Custom Scales'[Points]),Documents[DocumentType]="ADMIT"),
				    "TableDisch",CALCULATE(AVERAGE('Outcomes Custom Scales'[Points]),Documents[DocumentType]="DISCH"),
				    "StartScoreValues",CALCULATE(CONCATENATEX(DISTINCT(Assessments[LibraryScaleValue_ID]),Assessments[LibraryScaleValue_ID],", ",Assessments[LibraryScaleValue_ID],ASC),Documents[DocumentType]="ADMIT"),
				    "EndScoreValues",CALCULATE(CONCATENATEX(DISTINCT(Assessments[LibraryScaleValue_ID]),Assessments[LibraryScaleValue_ID],", ",Assessments[LibraryScaleValue_ID],ASC),Documents[DocumentType]="DISCH")
				)

	annotation PBI_Id = 69afafddf20a4bb1a962f6764722afa4


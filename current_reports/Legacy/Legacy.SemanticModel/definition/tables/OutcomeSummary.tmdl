	column Status =
			
			// IF(
			//     ISBLANK(OutcomeSummary[EvalNEW])=FALSE()&&
			//     ISBLANK(OutcomeSummary[TableDisch])=FALSE()&&
			//     OutcomeSummary[EvalNEW]<>1,
			//     "Included",
			//     "Excluded"
			// )
			
			IF(
			    ISBLANK(OutcomeSummary[EvalNEW])=FALSE() && ISBLANK(OutcomeSummary[TableDisch])=FALSE() && OutcomeSummary[EvalNEW]<>1 && OutcomeSummary[IsCrosswalked]=TRUE(),
			    "Included",
			    "Excluded"
			)
		lineageTag: 8ce1dc5b-e068-4fdb-9abd-78a7fa4f3106
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column EvalNEW = ```
			
			// IF(
			//     RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility","(b) Section GG Self Care"} && 
			//     OutcomeSummary[Criteria Start] IN {"ANA","Missing"},0,
			//     OutcomeSummary[TableEval]
			// )
			
			
			IF(
			    RELATED(Dictionary[Family]) IN {"(a) Section GG Mobility","(b) Section GG Self Care"} &&
			    ISBLANK(OutcomeSummary[StartScoreValues]) || 
			    (
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15102") || //score value of 07
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15103") || //score value of 08
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15104") || //score value of 10
			        CONTAINSSTRING(OutcomeSummary[StartScoreValues],"15105") //score value of 88
			    ),
			    0,
			    OutcomeSummary[TableEval]
			)
			```
		formatString: 0.00%;-0.00%;0.00%

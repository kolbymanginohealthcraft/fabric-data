	column 'Payer Categorization' = ```
			
			// IF(
			//     COUNTROWS(RELATEDTABLE(vw_PatientPayers))=1,
			//     MINX(RELATEDTABLE(vw_PatientPayers),vw_PatientPayers[Payer Group]),
			//     "(8) Multiple Payers"
			// )
			
			VAR RelatedRows =
			    RELATEDTABLE(vw_PatientPayers)
			VAR DistinctGroups =
			    SUMMARIZE(RelatedRows, vw_PatientPayers[Payer Group])
			RETURN
			IF(
			    COUNTROWS(DistinctGroups) = 1,
			    MAXX(DistinctGroups, vw_PatientPayers[Payer Group]),
			    "(8) Multiple Payers"
			)
			
			```
		displayFolder: Cohort Selection
		lineageTag: d0cbab09-f8ef-4783-b638-ad7663d844dc
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Diagnostic Category' =
			
			CALCULATE(
			    FIRSTNONBLANK(DiagnosisCode[L2],1),
			    Diagnosis[DiagnosisType]="Medical",

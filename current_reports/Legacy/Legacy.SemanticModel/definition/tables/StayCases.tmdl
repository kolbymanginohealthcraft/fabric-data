	column UniqueDays =
			
			CALCULATE(
			    COUNTROWS(
			        FILTER(
			            ALL('Calendar'),
			            COUNTROWS(
			                FILTER(
			                    CaseTracks,
			                    CaseTracks[PatientCase_ID] = SELECTEDVALUE(StayCases[PatientCase_ID])
			                    && 'Calendar'[Date] >= CaseTracks[StartDate]
			                    && 'Calendar'[Date] <= CaseTracks[EndDate]
			                )
			            ) > 0
			        )
			    )
			)
			
			// DATEDIFF(StayCases[TherapyStartDate]-1,StayCases[TherapyEndDate],DAY)
		formatString: 0
		lineageTag: 1c4c1339-fd47-4f67-b92b-1e2e15c8dd49
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic


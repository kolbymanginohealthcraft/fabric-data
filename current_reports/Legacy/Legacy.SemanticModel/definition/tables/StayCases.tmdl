table StayCases
	lineageTag: 5c3d551f-2ca1-46e1-bed1-bae0250f8e70

	measure 'Avg Number of Disciplines' =
			
			DIVIDE(
			    SUMX(
			        StayCases,
			        [Total Disciplines]
			    ),
			    CALCULATE(
			        [Total Cases],
			        FILTER(
			            StayCases,
			            [Total Disciplines]>0
			        )
			    )
			)
		lineageTag: 2f69ee22-ffe4-4459-a544-7a56e8efd742


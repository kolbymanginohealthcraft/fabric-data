			    AND(
			        RELATED('Payer Buckets'[Payer Grouping])="(b) Medicare Part B and HMO B",
			        MINX(RELATEDTABLE(Payers),Payers[Special Needs])="ISNP"
			    ),
			    "ISNP",
			    IF(
			        RELATED('Payer Buckets'[Payer Grouping])="(b) Medicare Part B and HMO B",
			        "Other Part B",
			        "Other Payers"

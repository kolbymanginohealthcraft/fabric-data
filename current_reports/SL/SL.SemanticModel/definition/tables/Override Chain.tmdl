		annotation SummarizationSetBy = Automatic

	column Name
		lineageTag: 7b32edd4-b2fb-43cf-b157-ea898b8e3b37
		summarizeBy: none
		isNameInferred
		sourceColumn: [Name]

		annotation SummarizationSetBy = Automatic

	partition 'Override Chain' = calculated
		mode: import

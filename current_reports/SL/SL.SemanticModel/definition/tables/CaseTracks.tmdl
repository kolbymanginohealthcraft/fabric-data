	column StartDate
		dataType: dateTime
		formatString: Short Date
		lineageTag: 8a906e0f-f580-4e1d-ad13-9f106f4d5587
		summarizeBy: none
		sourceColumn: StartDate

		variation Variation
			isDefault
			relationship: f3681b27-4766-48b5-889c-845f3aefb9be
			defaultHierarchy: LocalDateTable_3002af17-beee-4a55-b8e2-18c5467ab6fc.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column EndDate
		dataType: dateTime
		formatString: Short Date
		lineageTag: b1bfb695-b01d-4f69-9965-be761954bea4
		summarizeBy: none
		sourceColumn: EndDate

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Evaluating Therapist' =
			
			CALCULATE(
			    FIRSTNONBLANK(Employees[Name],1),
			    Service[Type]="Eval"
			)
		lineageTag: 848867f7-6e2d-4485-8d78-cdc7284719a8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Evaluation Method' =
			
			// CALCULATE(
			//     FIRSTNONBLANK(Employees[Name],1),
			//     Service[Type]="Eval"
			// )
			
			IF(
			    CALCULATE(MIN(Treatments[LaborDate]))=CALCULATE(MIN(Treatments[LaborDate]),ISBLANK(Telehealth[TxSession_ID])=FALSE()),
			    "Telehealth",
			    "In-Person"
			)
			
			// CALCULATE(MIN(Treatments[LaborDate]))
			
			// CALCULATE(MIN(Treatments[LaborDate]),ISBLANK(Telehealth[TxSession_ID])=FALSE())
		lineageTag: 5c1cd6a9-99b4-4dff-aa0f-2973eb181770
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Evaluating Therapist FTE Type' =
			
			CALCULATE(
			    FIRSTNONBLANK(FTEType[Type],1),
			    Service[Type]="Eval"
			)
		lineageTag: a10f132b-0863-41e5-8d0f-2d914a6a56c3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Admit Level: Walk 10 ft' =
			
			CALCULATE(
			    [Admit Level],
			    Dictionary[Name] = "I. Walk 10 feet"
			)
		lineageTag: 44545570-b036-405f-9011-993abc0b7481
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Admit Level: Gait Speed' =
			
			CALCULATE(
			    [Admit Level],
			    Dictionary[Name] = "4MWT Gait Speed Test"
			)
		lineageTag: 1124b76f-684d-4a87-9029-b4daf2e22c15
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Duration =
			
			DATEDIFF(
			    CaseTracks[StartDate]-1,
			    COALESCE(CaseTracks[EndDate],MAX('Calendar'[Date])),
			    DAY
			)
		formatString: 0
		lineageTag: 8159916a-8be4-4f2f-acd8-3c7d7d4bcf44
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition CaseTracks = m
		mode: import
		queryGroup: Patient
		source =
				let
				    Source = dbo_vw_CaseTracks,
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"StartDate", type date}, {"EndDate", type date}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation


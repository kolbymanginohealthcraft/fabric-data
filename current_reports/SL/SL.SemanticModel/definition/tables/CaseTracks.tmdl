table CaseTracks
	lineageTag: 2f70d1c5-9fb4-4d9d-941b-5ce3ae7e833e

	measure 'Total Tracks' =
			
			// COUNTROWS(CaseTracks)
			
			CALCULATE(
			    COUNTROWS(CaseTracks),
			    FILTER(
			        CaseTracks,
			        [Total Measurements]>0
			    )
			)
		formatString: #,0
		lineageTag: 1ea16cd9-2277-418c-9247-407e5b7127e4

	measure 'Min Track Start' = MIN(CaseTracks[StartDate])
		formatString: Short Date
		lineageTag: 8c853bd8-baac-4971-9553-54f573b0b2f6

	measure 'Max Track End' = MAX(CaseTracks[EndDate])
		formatString: Short Date
		lineageTag: 0b208edd-95a4-4fde-aa15-820d858f21e4

	measure 'Track Duration' =
			
			DATEDIFF(
			    SELECTEDVALUE(CaseTracks[StartDate])-1,
			    SELECTEDVALUE(CaseTracks[EndDate]),
			    DAY
			)
		lineageTag: 10b54b7b-2897-4b99-95a2-f27fa591f12a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Track Start' = SELECTEDVALUE(CaseTracks[StartDate])
		lineageTag: 31431a88-e9e7-48c4-9a60-67cba3d2b128

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Caseload =
			
			// var StartDate = MIN('Calendar'[Date])
			// var EndDate = MAX('Calendar'[Date])
			
			var StartDate = TODAY()
			var EndDate = TODAY()
			
			RETURN
			CALCULATE(
			    // COUNTROWS(CaseTracks),
			    // DISTINCTCOUNT(CaseTracks[PatientCase_ID]),
			    COUNTROWS(StayCases),
			    FILTER(
			        ALLEXCEPT(CaseTracks,CaseTracks[Discipline]),
			        CaseTracks[StartDate]<=EndDate &&
			        COALESCE(CaseTracks[EndDate],EndDate)>=StartDate
			    )
			)
		formatString: #,0
		lineageTag: 2c62c61b-c686-4d2e-ad93-7abf839b3f83

	measure Caseload3 =
			
			// var StartDate = MIN('Calendar'[Date])
			// var EndDate = MAX('Calendar'[Date])
			
			var StartDate = TODAY()
			var EndDate = TODAY()
			
			RETURN
			CALCULATE(
			    COUNTROWS(CaseTracks),
			    FILTER(
			        ALLEXCEPT(CaseTracks,CaseTracks[Discipline]),
			        CaseTracks[StartDate]<=EndDate &&
			        COALESCE(CaseTracks[EndDate],EndDate)>=StartDate
			    )
			)
		formatString: #,0
		lineageTag: ec17a7d1-1f2e-4c8c-b3f6-9f345dcdcc2d

	measure 'Caseload Subtitle' =
			
			"Total open tracks = "&FORMAT([Caseload3],"#,###")&" ("&FORMAT([Caseload],"#,###")&" patients"&")"
		lineageTag: 196a0217-59ef-4695-9a2c-61b770a37560

		annotation PBI_FormatHint = {"isGeneralNumber":true}


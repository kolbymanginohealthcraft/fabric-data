	measure 'Timeline PaddingLeft' =
			
			var OverallStartDate = Timeline[Timeline Start]
			var StartDate = SELECTEDVALUE(Timeline[Start])
			var result = DATEDIFF(OverallStartDate,StartDate,DAY)
			return result
		lineageTag: 345cf627-a8fe-4e5b-9318-4128adfe38e6


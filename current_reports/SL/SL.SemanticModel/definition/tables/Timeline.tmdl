	partition Timeline = calculated
		mode: import
		source = ```
				
				FILTER(
				    UNION(
				        //cases
				        SELECTCOLUMNS(StayCases,"CaseID",StayCases[PatientCase_ID],"ItemID",StayCases[PatientCase_ID],"Item","A: Case","Detail",BLANK(),"Start",StayCases[TherapyStartDate],"End",StayCases[TherapyEndDate]),
				        
				        //payers
				        SELECTCOLUMNS(vw_PatientPayers,"CaseID",RELATED(StayCases[PatientCase_ID]),"ItemID",vw_PatientPayers[Payer_ID],"Item","B: Payer","Detail",RELATED(Payers[Name]),"Start",vw_PatientPayers[FromDate],"End",vw_PatientPayers[ThruDate]),
				
				        //tracks
				        SELECTCOLUMNS(CaseTracks,"CaseID",RELATED(StayCases[PatientCase_ID]),"ItemID",CaseTracks[TxTrack_ID],"Item","C: Track","Detail",RELATED(Disciplines[Ordered Discipline]),"Start",CaseTracks[StartDate],"End",CaseTracks[EndDate]),
				
				        //visits
				        SELECTCOLUMNS(Treatments,"CaseID",RELATED(StayCases[PatientCase_ID]),"ItemID",Treatments[SessionId],"Item","D: Visit","Detail",RELATED(Disciplines[Ordered Discipline]),"Start",Treatments[LaborDate],"End",Treatments[LaborDate])
				    ),
				    NOT(ISBLANK([CaseID]))
				)
				```

	annotation PBI_Id = 8d7d386739aa464c9ee1ada423d75407


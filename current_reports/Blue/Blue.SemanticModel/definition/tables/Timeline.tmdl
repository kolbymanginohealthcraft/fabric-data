	measure 'Timeline End' =
			
			// CALCULATE(
			//     MIN(Timeline[Start]),
			//     ALLSELECTED(Timeline[CaseID])
			// )
			
			// MINX(
			//     KEEPFILTERS(VALUES('Timeline'[CaseID])),

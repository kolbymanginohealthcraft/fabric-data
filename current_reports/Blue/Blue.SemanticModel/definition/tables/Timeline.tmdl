			)
		lineageTag: 190dc795-5b52-44b7-8044-5a563ba13091

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeline PaddingLeft' =
			
			var OverallStartDate = Timeline[Timeline Start]
			var StartDate = SELECTEDVALUE(Timeline[Start])
			var result = DATEDIFF(OverallStartDate,StartDate,DAY)
			return result
		lineageTag: 345cf627-a8fe-4e5b-9318-4128adfe38e6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeline SVG' =
			
			
			var canvasWidth = 648
			var canvasHeight = 172
			var caseStartDate = [Timeline Start]
			var caseStartEnd = [Timeline End]
			
			return
			
			//prefix
			"data:image/svg+xml;utf8,"&
			
			//setup
			"<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//visit PT
			"<line x1=""7.75"" y1=""77"" x2=""7.75"" y2=""96"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//visit OT
			"<line x1=""168.75"" y1=""112"" x2=""168.75"" y2=""131"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//visit ST
			"<line x1=""387.75"" y1=""147"" x2=""387.75"" y2=""166"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//suffix
			"</svg>"
		lineageTag: f6811c12-a478-4167-9cdb-c06c11f21117
		dataCategory: ImageUrl

		annotation PBI_FormatHint = {"isGeneralNumber":true}


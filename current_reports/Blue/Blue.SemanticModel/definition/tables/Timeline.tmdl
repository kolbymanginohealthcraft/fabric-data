table Timeline
	lineageTag: b222de8b-7d8b-4866-8d69-3ba205ef4851

	measure Duration =
			
			DATEDIFF(
			    SELECTEDVALUE(Timeline[Start])-1,
			    SELECTEDVALUE(Timeline[End]),
			    DAY
			)
		lineageTag: 2a0dcc9a-ecb6-48ba-8c4c-7e888a86c3a6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeline Start' =
			
			// CALCULATE(

table 'Diagnosis Hierarchy'
	lineageTag: 2ba5eb0b-2dba-4d9a-9963-0232bce43f4f

	measure 'Diagnosis Hierarchy Unique Values' =
			
			// SWITCH(
			//     MIN('Diagnosis Hierarchy'[Diagnosis Hierarchy]),
			//     "L1",FORMAT(DISTINCTCOUNT(DiagnosisCode[L1]),"#,##0")&" distinct values",
			//     "L2",FORMAT(DISTINCTCOUNT(DiagnosisCode[L2]),"#,##0")&" distinct values",
			//     "L3",FORMAT(DISTINCTCOUNT(DiagnosisCode[L3]),"#,##0")&" distinct values",
			//     "L4",FORMAT(DISTINCTCOUNT(DiagnosisCode[L4]),"#,##0")&" distinct values",
			//     BLANK()
			// )
			
			FORMAT(
			    SWITCH(
			        MIN('Diagnosis Hierarchy'[Diagnosis Hierarchy]),
			        "L1",DISTINCTCOUNT(DiagnosisCode[L1]),
			        "L2",DISTINCTCOUNT(DiagnosisCode[L2]),
			        "L3",DISTINCTCOUNT(DiagnosisCode[L3]),
			        "L4",DISTINCTCOUNT(DiagnosisCode[L4]),
			        BLANK()
			    ),
			    "#,##0"
			)
			&" distinct values"
		formatString: #,0
		lineageTag: 7f3f0360-d987-4ec5-8fab-147dead0b784

	column 'Diagnosis Hierarchy'
		lineageTag: 1ba53d6b-7be3-47fd-be4f-f3f5d1e50bcd
		summarizeBy: none
		sourceColumn: [Value1]
		sortByColumn: 'Diagnosis Hierarchy Order'

		relatedColumnDetails

		summarizeBy: sum
		sourceColumn: [Value3]

		annotation SummarizationSetBy = Automatic

	column 'Diagnosis Hierarchy Selection' =
			
			// 'Diagnosis Hierarchy'[Diagnosis Hierarchy]
			
			SWITCH(
			    'Diagnosis Hierarchy'[Diagnosis Hierarchy],
			    "L1","Dx Level 1 (most broad)",
			    "L2","Dx Level 2",
			    "L3","Dx Level 3",
			    "L4","Dx Level 4 (most granular)",
			    BLANK()
			)
		lineageTag: d274c04a-917a-4478-89f4-915f9b15a4e1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Diagnosis Hierarchy' = calculated
		mode: import
		source =
				{
				    ("L1", NAMEOF('DX_Cases'[L1]), 0),
				    ("L2", NAMEOF('DX_Cases'[L2]), 1),
				    ("L3", NAMEOF('DX_Cases'[L3]), 2),

node_modules/
.env

# Python
__pycache__/
*.pyc

# Nested standalone repo, kept locally for agent context only.
# Has its own git/GitHub (kolbymanginohealthcraft/people-dashboard) — do not track here.
PeopleDashboard/
databases.json
.token-cache.json
*.pbi/localSettings.json
# PBIP local user settings — nested-path match (the line above only matches top-level)
**/.pbi/localSettings.json

# All data lives in data/ — never commit generated/PHI CSVs. Ignore every CSV under data/
# EXCEPT the two tracked SharePoint inputs (crosswalk + custom scales).
data/*.csv
!data/Outcomes Crosswalk.csv
!data/Outcomes Custom Scales.csv
!data/satisfaction-scoring.csv
!data/satisfaction-dictionary.csv

# Generated / debug artifacts
queries/.rendered*.sql
queries/.pull.log
queries/.debug-render.js

# Binary workbooks (may contain sensitive metrics) — keep local only
*.xlsx

# Compiled Power BI binaries — huge, may embed imported data (PHI). Keep PBIP text format only.
*.pbix

# Power BI Desktop local binary data cache (never commit)
**/.pbi/*.abf

model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Patient

	annotation PBI_QueryGroupOrder = 3

queryGroup Payer

	annotation PBI_QueryGroupOrder = 4

queryGroup Outcomes

	annotation PBI_QueryGroupOrder = 5

queryGroup Visits

	annotation PBI_QueryGroupOrder = 6

queryGroup Procedures

	annotation PBI_QueryGroupOrder = 7

queryGroup Discharge

	annotation PBI_QueryGroupOrder = 8

queryGroup Diagnoses

	annotation PBI_QueryGroupOrder = 9

queryGroup Places

	annotation PBI_QueryGroupOrder = 0

queryGroup People

	annotation PBI_QueryGroupOrder = 2

queryGroup Management

	annotation PBI_QueryGroupOrder = 9

queryGroup FabricTables

	annotation PBI_QueryGroupOrder = 10

annotation PBI_QueryOrder = ["Patients","PatientStays","StayCases","CaseTracks","vw_PatientPayers","Payers","DischargeDestination","Documents","Assessments","Outcomes Crosswalk","Outcomes Custom Scales","Facility","Dictionary","Outcome Families","Treatments","TreatmentsDetails","Disciplines","Service","Basis","DischargeReason","Diagnosis","DiagnosisCode","Telehealth","MeasureTable","DestinationPage","IntakeSources","vw_UpnFacilityAccess","Employees","CaseTrackDays","PriorLivingEnvironment","ExpectedDischargeDestination","EDD","EmployeeBasicInfo","FTEType","Physician","PLE","PatientScreens","Peer Group","PatientLevelOptionalServices_Instance","PatientLevelOptionalServices_Service","CohortAnchorDate","_CohortAnchorDateText","_SilverSource","_PreImpl","_NetHealthBronze","_RoxAegis","_QualifyingCaseIdsSql","_QualifyingCases","_QualifyingTracks","_QualifyingStays","_QualifyingCaseIdList","dbo_vw_PatientStays","dbo_vw_StayCases","dbo_vw_CaseTracks","dbo vw_AllEvalsAndDischargesLight","excelOutcomesCrosswalk","dbo vw_AllEvalsAndDischargesLight_Items","excelOutcomesCustomScales","dbo_vw_Treatments","dbo_vw_Diagnosis","excel_Employee_FTE_status_vs_patient_outcomes_WD_Roster","dbo_vw_UpnFacilityAccess","_AegisPatient","Unit of Analysis","Time Basis"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]


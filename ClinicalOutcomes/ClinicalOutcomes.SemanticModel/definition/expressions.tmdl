/// Cohort anchor date — the pillar that defines "qualifying" across every
/// fact table. ROLLING 12-month window (today − 365 days); switch to a fixed
/// `#date(YYYY, M, D)` if a stable window is wanted.
expression CohortAnchorDate = Date.From(Date.AddDays(DateTime.Date(DateTime.LocalNow()), -365))
	lineageTag: aaaaaaaa-0000-0000-0000-000000000001
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Date

/// String form of CohortAnchorDate, inlined into SQL strings.
expression _CohortAnchorDateText = Date.ToText(CohortAnchorDate, [Format="yyyy-MM-dd"])
	lineageTag: aaaaaaaa-0000-0000-0000-000000000002
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text


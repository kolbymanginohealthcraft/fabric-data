expression dbo_vw_Treatments =
		let
		    Source = Value.NativeQuery(_SilverSource, "SELECT tm.SessionId, MAX(tm.PersonId) AS Person_ID, MAX(ts.SessionDate) AS LaborDate, MAX(CAST(tm.AssistantModifier AS int)) AS AssistantModifier, MAX(ts.TrackId) AS TxTrack_ID, SUM(tm.Duration) AS Duration, SUM(tm.Units) AS Units, svc.ServiceCode FROM dbo.treatmentminute tm INNER JOIN dbo.treatmentsession ts ON ts.NetHealthId = tm.SessionId INNER JOIN (SELECT TrackId FROM dbo.treatmentsession GROUP BY TrackId HAVING MAX(SessionDate) >= '" & _CohortAnchorDateText & "') tw ON tw.TrackId = ts.TrackId LEFT JOIN dbo.service svc ON svc.NetHealthId = tm.ServiceId GROUP BY tm.SessionId, svc.ServiceCode")
		in
		    Source
	lineageTag: 1ae51eca-e144-4660-b7bb-3139dec4822b
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression dbo_vw_Diagnosis =
		let
		    Source = Value.NativeQuery(_NetHealthBronze, "SELECT d.TxDocument_ID, d.DiagnosisType, d.DisplayOrder, d.DiagnosisCode_ID, d.OnsetDate FROM dbo.TxDiagnosis d INNER JOIN dbo.TxDocument doc ON doc.TxDocument_ID = d.TxDocument_ID AND doc.DocumentType IN ('EVAL','DISCH') AND ISNULL(doc.IsInactive,0)=0 INNER JOIN dbo.TxTrack tt ON tt.TxTrack_ID = doc.TxTrack_ID AND ISNULL(tt.IsDeletedTrack,0)=0 WHERE ISNULL(d.IsInactive,0)=0 AND tt.PatientCase_ID IN " & _QualifyingCaseIdsSql)
		in
		    Source

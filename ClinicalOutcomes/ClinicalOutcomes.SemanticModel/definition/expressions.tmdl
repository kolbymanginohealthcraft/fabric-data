/// REUSABLE SQL FRAGMENT: subquery returning every qualifying PatientCase_ID.
/// A case qualifies if its case-level TherapyEndDate is in window (SNF signal)
/// OR any of its CaseTracks has EndDate in window (SL signal — case-level end
/// is often null/unreliable for SL, so the track is authoritative). Inlined
/// into each fact table's WHERE so the cohort filter pushes down to Fabric SQL.
expression _QualifyingCaseIdsSql =
		"(SELECT pc.PatientCase_ID FROM dbo.PatientCase pc WHERE pc.EndDate >= '" & _CohortAnchorDateText & "' AND ISNULL(pc.IsDeletedCase,0)=0 " &
		"UNION SELECT tt.PatientCase_ID FROM dbo.TxTrack tt WHERE tt.EndDate >= '" & _CohortAnchorDateText & "' AND ISNULL(tt.IsDeletedTrack,0)=0)"
	lineageTag: aaaaaaaa-0000-0000-0000-000000000007
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

/// COHORT ANCHOR — full case rows for every qualifying PatientCase_ID.
expression _QualifyingCases = Value.NativeQuery(_NetHealthBronze, "SELECT pc.PatientCase_ID, pc.Stay_ID, pc.StartDate AS TherapyStartDate, pc.EndDate AS TherapyEndDate, pc.DischargedTo_ID, pc.EndReason_ID, pc.TypeOfCare FROM dbo.PatientCase pc WHERE ISNULL(pc.IsDeletedCase,0)=0 AND pc.PatientCase_ID IN " & _QualifyingCaseIdsSql)
	lineageTag: aaaaaaaa-0000-0000-0000-000000000008
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

/// All tracks belonging to qualifying cases.
expression _QualifyingTracks = Value.NativeQuery(_NetHealthBronze, "SELECT tt.TxTrack_ID, tt.PatientCase_ID, tt.Discipline, tt.StartDate, tt.EndDate FROM dbo.TxTrack tt WHERE ISNULL(tt.IsDeletedTrack,0)=0 AND tt.PatientCase_ID IN " & _QualifyingCaseIdsSql)
	lineageTag: aaaaaaaa-0000-0000-0000-000000000009
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

/// Stays containing qualifying cases. DISTINCT in case a Stay spans cases.
expression _QualifyingStays = Value.NativeQuery(_NetHealthBronze, "SELECT DISTINCT s.Stay_ID, s.Resident_ID AS PatientID, s.AdmitDate, s.DischargeDate, s.IntakeSource_ID, s.MedicalRecordNumber FROM dbo.Stay s WHERE s.Stay_ID IN (SELECT pc.Stay_ID FROM dbo.PatientCase pc WHERE pc.PatientCase_ID IN " & _QualifyingCaseIdsSql & ")")
	lineageTag: aaaaaaaa-0000-0000-0000-000000000010
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

/// Comma-separated text of every qualifying PatientCase_ID. Inlined into
/// Silver-side queries as a literal IN list (cohort filter can't fold
/// cross-database). Used by downstream fact tables in a later phase.
expression _QualifyingCaseIdList =
		let
		    ids = Table.Column(_QualifyingCases, "PatientCase_ID"),
		    text = Text.Combine(List.Transform(ids, Number.ToText), ",")
		in
		    text
	lineageTag: aaaaaaaa-0000-0000-0000-000000000011
	queryGroup: FabricTables

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text


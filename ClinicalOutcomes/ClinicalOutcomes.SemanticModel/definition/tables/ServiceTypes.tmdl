	partition ServiceTypes = calculated
		mode: import
		source = ```

				DATATABLE (
				    "SortOrder", INTEGER,
				    "ServiceType", STRING,
				    {
				        { 1, "Case" },
				        { 2, "Track - PT" },
				        { 3, "Track - OT" },
				        { 4, "Track - ST" },
				        { 5, "PLOS - Any" },
				        { 6, "PLOS - Nursing Restorative" },
				        { 7, "PLOS - Rehab Tech" },
				        { 8, "PLOS - Screens" },
				        { 9, "PLOS - Wellness" },
				        { 10, "Any Service" },
				        { 11, "No Service" },
				        { 12, "Total Patients" },
				        { 13, "% Touched (Any Service)" },
				        { 14, "% On Caseload" },
				        { 15, "% On PLOS" }
				    }
				)

				```

	annotation PBI_Id = 0c8c52d1ff1645419346dad01ef3f12a

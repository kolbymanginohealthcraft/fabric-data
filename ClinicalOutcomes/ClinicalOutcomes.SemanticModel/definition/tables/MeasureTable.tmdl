	measure 'ActiveFilters: Place of Service' =
			
			IF(
			    ISFILTERED(IntakeSources[Name]),
			    CONCATENATEX(VALUES(IntakeSources[Name]),IntakeSources[Name],", "),
			    IF(
			        ISFILTERED(IntakeSources[SourceType]),
			        CONCATENATEX(VALUES(IntakeSources[SourceType]),IntakeSources[SourceType],", "),
			        "All"
			    )
			)
		lineageTag: 767eebd5-a157-4979-8d5a-8478900b3684

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: All' = ```
			
			var newline = UNICHAR(13)&UNICHAR(10)
			var multiline = REPT(newline,2)
			
			
			var payer = 
			IF(ISFILTERED('Payer Buckets'[Payer Categorization]) || ISFILTERED('Payer Buckets'[Payer Grouping]),"Payer:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED('Payer Buckets'[Payer Categorization]),CONCATENATEX(VALUES('Payer Buckets'[PCLabel]),'Payer Buckets'[PCLabel],", "),
			    ISFILTERED('Payer Buckets'[Payer Grouping]),CONCATENATEX(VALUES('Payer Buckets'[PGLabel]),'Payer Buckets'[PGLabel],", ")
			))
			
			var agerange = 
			IF(ISFILTERED(StayCases[Age Range]),"Age Range:"&newline&
			CONCATENATEX(VALUES(StayCases[Age Range]),StayCases[Age Range],", ")
			)
			
			var diagnosis = 
			IF(NOT(ISFILTERED(DX_Cases[L1]) || ISFILTERED(DX_Cases[L2]) || ISFILTERED(DX_Cases[L3]) || ISFILTERED(DX_Cases[L4])),BLANK(),
			IF(ISFILTERED(DX_Cases[Type]),SELECTEDVALUE(DX_Cases[Type])&" ")&
			"Diagnosis:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DX_Cases[L4]),CONCATENATEX(VALUES(DX_Cases[L4]),DX_Cases[L4],", "),
			    ISFILTERED(DX_Cases[L3]),CONCATENATEX(VALUES(DX_Cases[L3]),DX_Cases[L3],", "),
			    ISFILTERED(DX_Cases[L2]),CONCATENATEX(VALUES(DX_Cases[L2]),DX_Cases[L2],", "),
			    ISFILTERED(DX_Cases[L1]),CONCATENATEX(VALUES(DX_Cases[L1]),DX_Cases[L1],", ")
			))
			
			var DCtype = 
			IF(ISFILTERED(DischargeDestination[Type]),"D/C Type"&newline&
			CONCATENATEX(VALUES(DischargeDestination[Type]),DischargeDestination[Type],", ")
			)
			
			var DCdest = 
			IF(ISFILTERED(DischargeDestination[Setting]) || ISFILTERED(DischargeDestination[Group]),"D/C Destination"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DischargeDestination[Setting]),CONCATENATEX(VALUES(DischargeDestination[Setting]),DischargeDestination[Setting],", "),
			    ISFILTERED(DischargeDestination[Group]),CONCATENATEX(VALUES(DischargeDestination[Group]),DischargeDestination[Group],", ")
			))
			
			var DCexpected = 
			IF(ISFILTERED(StayCases[Expected Discharge Destination]),"Expected D/C Destination:"&newline&
			CONCATENATEX(VALUES(StayCases[Expected Discharge Destination]),StayCases[Expected Discharge Destination],", ")
			)
			
			var placeofservice = 
			IF(ISFILTERED(IntakeSources[Name]) || ISFILTERED(IntakeSources[SourceType]),"Place of Service:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(IntakeSources[Name]),CONCATENATEX(VALUES(IntakeSources[Name]),IntakeSources[Name],", "),
			    ISFILTERED(IntakeSources[SourceType]),CONCATENATEX(VALUES(IntakeSources[SourceType]),IntakeSources[SourceType],", ")
			))
			
			
			var concatTable = FILTER({payer,agerange,diagnosis,DCtype,DCdest,DCexpected,placeofservice},NOT(ISBLANK([Value])))
			
			return COALESCE(CONCATENATEX(concatTable,[Value],multiline),"None")
			```

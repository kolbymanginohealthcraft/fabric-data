	measure 'Results Distribution Subtitle' =
			
			var casesincluded = [Total Cases] //because visual will be filtered to exclude N/A's
			var casestotal = CALCULATE([Total Cases],REMOVEFILTERS(StayCases[Case Result]))
			var casesexcluded = casestotal-casesincluded+0
			return
			"Includes "&FORMAT(casesincluded,"#,###")&" of the total "&FORMAT(casestotal,"#,###")&" discharges (excludes "&FORMAT(casesexcluded,"#,##0")&" without valid outcomes)"

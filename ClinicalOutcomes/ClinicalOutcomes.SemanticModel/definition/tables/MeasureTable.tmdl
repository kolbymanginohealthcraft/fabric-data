	measure 'Outcomes SVG' = ```
			
			
			var canvasWidth = 774
			var canvasHeight = 70
			
			var endLinePad_x = .01 //prev was .12
			var endLinePad_y = .33 //top and bottom padding for end lines
			
			var progressLineColor = IF([Gain]>0,"#7fbc42","#D64550")
			var progressLineSize = 15

			return
			
			//check if valid count > 0
			IF(ISBLANK([Total Measurements]),BLANK(),
			
			//prefix
			"data:image/svg+xml;utf8,<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//left end line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&endLinePad_x*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke=""#3DB3E3"" 
			    stroke-width=""2""
			/>"&
			
			//right end line
			"<line 
			    x1="""&(1-endLinePad_x)*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke=""#3DB3E3"" 
			    stroke-width=""2""
			/>"&
			
			//span line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&.50*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&.50*canvasHeight&""" 
			    stroke=""#3DB3E3""
			    stroke-width=""2""
			/>"&
			
			//progress line
			"<line 
			    x1="""&[Admit Level]*canvasWidth&""" 
			    y1="""&.5*canvasHeight&""" 
			    x2="""&[Discharge Level]*canvasWidth&""" 
			    y2="""&.5*canvasHeight&""" 
			    stroke="""&progressLineColor&""" 
			    stroke-width="""&progressLineSize&"""
			/>"&
			
			//admit circle
			"<circle 
			    cx="""&[Admit Level]*canvasWidth&""" 
			    cy="""&.5*canvasHeight&""" 
			    r="""&(1-2*endLinePad_y)*canvasHeight&""" 
			    fill=""#0C436A""
			/>"&
			
			//discharge circle
			"<circle 
			    cx="""&[Discharge Level]*canvasWidth&""" 
			    cy="""&.5*canvasHeight&""" 
			    r="""&(1-2*endLinePad_y)*canvasHeight&""" 
			    fill=""#0C436A""
			/>"&
			
			//suffix
			"</svg>"
			
			)
			```
		displayFolder: Outcomes
		lineageTag: 601abb3b-788a-4975-b76d-06984918829f
		dataCategory: ImageUrl

		annotation PBI_FormatHint = {"isGeneralNumber":true}
	measure 'Outcomes SVG SL' = ```
			
			
			var canvasWidth = 774
			var canvasHeight = 25
			
			var endLinePad_x = .01 //prev was .12
			var endLinePad_y = .35 //top and bottom padding for end lines
			
			var progressLineColor = IF([Gain]>0,"#7fbc42","#D64550")
			var progressLineSize = 7

			var trackColor = "#D0D0D0"

			return
			
			//check if valid count > 0
			IF(ISBLANK([Total Measurements]),BLANK(),
			
			//prefix
			"data:image/svg+xml;utf8,<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//left end line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&endLinePad_x*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke="""&trackColor&""" 
			    stroke-width=""2""
			/>"&
			
			//right end line
			"<line 
			    x1="""&(1-endLinePad_x)*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke="""&trackColor&""" 
			    stroke-width=""2""
			/>"&
			
			//span line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&.50*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&.50*canvasHeight&""" 
			    stroke="""&trackColor&"""
			    stroke-width=""2""
			/>"&
			
			//progress line
			"<line 
			    x1="""&[Admit Level]*canvasWidth&""" 
			    y1="""&.5*canvasHeight&""" 
			    x2="""&[Discharge Level]*canvasWidth&""" 
			    y2="""&.5*canvasHeight&""" 
			    stroke="""&progressLineColor&""" 
			    stroke-width="""&progressLineSize&"""
			/>"&
			
			//admit circle
			"<circle 
			    cx="""&[Admit Level]*canvasWidth&""" 
			    cy="""&.5*canvasHeight&""" 
			    r="""&(1-2*endLinePad_y)*canvasHeight&""" 
			    fill=""#0C436A""
			/>"&
			
			//discharge circle
			"<circle 
			    cx="""&[Discharge Level]*canvasWidth&""" 
			    cy="""&.5*canvasHeight&""" 
			    r="""&(1-2*endLinePad_y)*canvasHeight&""" 
			    fill=""#0C436A""
			/>"&
			
			//suffix
			"</svg>"
			
			)
			```

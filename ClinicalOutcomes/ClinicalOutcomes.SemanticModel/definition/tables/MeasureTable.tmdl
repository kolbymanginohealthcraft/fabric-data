		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: D/C Status' = ```
			
			var newline = UNICHAR(13)&UNICHAR(10)
			var multiline = REPT(newline,2)
			
			var DCtype = 
			IF(ISFILTERED(DischargeDestination[Type]),"Type:"&" "&
			CONCATENATEX(VALUES(DischargeDestination[Type]),DischargeDestination[Type],", ")
			)
			
			var DCexpected = 
			IF(ISFILTERED(StayCases[Expected Discharge Destination]),"Expected:"&" "&
			CONCATENATEX(VALUES(StayCases[Expected Discharge Destination]),StayCases[Expected Discharge Destination],", ")
			)
			
			var DCdest = 
			IF(ISFILTERED(DischargeDestination[Setting]) || ISFILTERED(DischargeDestination[Group]),"Actual: "&" "&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DischargeDestination[Setting]),CONCATENATEX(VALUES(DischargeDestination[Setting]),DischargeDestination[Setting],", "),
			    ISFILTERED(DischargeDestination[Group]),CONCATENATEX(VALUES(DischargeDestination[Group]),DischargeDestination[Group],", ")
			))
			
			var concatTable = FILTER({DCtype,DCexpected,DCdest},NOT(ISBLANK([Value])))
			
			return COALESCE(CONCATENATEX(concatTable,[Value],newline),"All")
			```
		lineageTag: b8921e2b-f799-4a28-ad4a-daafa247d3b7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Patient' = ```
			
			var newline = UNICHAR(13)&UNICHAR(10)
			var multiline = REPT(newline,2)
			
			var payer = 
			IF(
			    ISFILTERED('Payer Buckets'[Payer Categorization]) || ISFILTERED('Payer Buckets'[Payer Grouping]) || ISFILTERED(Payers[Name]),
			    "Payer:" & " " &
			    // Add categorization or grouping label
			    SWITCH(
			        TRUE(),
			        ISFILTERED('Payer Buckets'[Payer Categorization]),
			            CONCATENATEX(VALUES('Payer Buckets'[PCLabel]), 'Payer Buckets'[PCLabel], ", "),
			        ISFILTERED('Payer Buckets'[Payer Grouping]),
			            CONCATENATEX(VALUES('Payer Buckets'[PGLabel]), 'Payer Buckets'[PGLabel], ", ")
			    ) &
			    // Add separator if both payer segment and name are filtered
			    IF(
			        (ISFILTERED('Payer Buckets'[Payer Categorization]) || ISFILTERED('Payer Buckets'[Payer Grouping])) 
			        && ISFILTERED(Payers[Name]),
			        " | ",
			        ""
			    ) &
			    // Append payer name if filtered
			    IF(
			        ISFILTERED(Payers[Name]),
			        CONCATENATEX(VALUES(Payers[Name]), Payers[Name], ", ")
			    )
			)
			
			
			var agerange = 
			IF(ISFILTERED(StayCases[Age Range]),"Age Range:"&" "&
			CONCATENATEX(VALUES(StayCases[Age Range]),StayCases[Age Range],", ")
			)
			
			var placeofresidence = 
			IF(ISFILTERED(IntakeSources[Name]) || ISFILTERED(IntakeSources[SourceType]),"Place of Residence:"&" "&
			SWITCH(
			    TRUE(),
			    ISFILTERED(IntakeSources[Name]),CONCATENATEX(VALUES(IntakeSources[Abbrev]),IntakeSources[Abbrev],", "),
			    ISFILTERED(IntakeSources[SourceType]),CONCATENATEX(VALUES(IntakeSources[SourceType]),IntakeSources[SourceType],", ")
			))
			
			var diagnosis = 
			IF(NOT(ISFILTERED(DX_Cases[L1]) || ISFILTERED(DX_Cases[L2]) || ISFILTERED(DX_Cases[L3]) || ISFILTERED(DX_Cases[L4])),BLANK(),
			IF(ISFILTERED(DX_Cases[Type]),SELECTEDVALUE(DX_Cases[Type])&" ")&
			"Diagnosis:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DX_Cases[L4]),CONCATENATEX(VALUES(DX_Cases[L4]),DX_Cases[L4],", "),
			    ISFILTERED(DX_Cases[L3]),CONCATENATEX(VALUES(DX_Cases[L3]),DX_Cases[L3],", "),
			    ISFILTERED(DX_Cases[L2]),CONCATENATEX(VALUES(DX_Cases[L2]),DX_Cases[L2],", "),
			    ISFILTERED(DX_Cases[L1]),CONCATENATEX(VALUES(DX_Cases[L1]),DX_Cases[L1],", ")
			))
			
			var concatTableShort = FILTER({payer,agerange,placeofresidence},NOT(ISBLANK([Value])))
			var concatTableLong = FILTER({diagnosis},NOT(ISBLANK([Value])))
			
			var stringShort = CONCATENATEX(concatTableShort,[Value],newline)
			var stringLong = CONCATENATEX(concatTableLong,[Value],multiline)
			var stringJoined = FILTER({stringShort,stringLong},NOT(ISBLANK([Value])))
			
			
			return COALESCE(CONCATENATEX(stringJoined,[Value],multiline),"All")
			```
		lineageTag: 5d05171c-2c72-4b67-83b7-37d583006310

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Test' =
			
			var pcat = IF(ISFILTERED('Payer Buckets'[Payer Categorization]),"Cat")
			var pgroup = IF(ISFILTERED('Payer Buckets'[Payer Grouping]),"Group")
			
			var pvalues = FILTER({pcat,pgroup},ISBLANK([Value])=FALSE())
			var concat = CONCATENATEX(pvalues,[Value],", ")
			return concat

			))
		displayFolder: Visits
		lineageTag: 3ddf0b87-4597-468d-8ca6-c2105ae2ce5b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Visits per Case Delta' =
			
			IF([Report Scope]="Filtered",[Visits per Case]-[Visits per Case BM])
		displayFolder: Visits
		lineageTag: a960c69c-0468-461e-9174-53963866865d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Cases with Outcomes' =
			
			CALCULATE(
			    [Total Cases],
			    FILTER(
			        StayCases,
			        [Total Measurements]>0
			    )
			)
		displayFolder: Cases
		lineageTag: 615f7fd3-41a8-4018-a306-5e4b2689285e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Measurements Recorded Text' =
			
			FORMAT([Total Measurements Recorded],"#,##0")&" total measurements from other exclusions"
		displayFolder: Outcomes
		lineageTag: e74ffaa3-949d-4dc7-ae1b-ef666cecc73e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Measurements Remove Filters' =
			
			CALCULATE(
			    [Total Measurements Recorded],
			    ALL(OutcomeSummary[Criteria Start]),
			    ALL(OutcomeSummary[Criteria End]),
			    ALL(OutcomeSummary[Story])
			)
		displayFolder: Outcomes
		lineageTag: 744e8907-30ae-4876-8379-b467373c8025

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gain per Hour BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Gain per Hour],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Outcomes
		lineageTag: 8b1303fd-bc8f-4c16-af90-6edec8d8a984

	measure 'Visits per Week BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Visits per Week],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.00
		displayFolder: Visits
		lineageTag: a7661c68-51e0-40e2-96dc-93cf36db8593

	measure 'Minutes per Week (part a)' =
			
			CALCULATE(
			    [Minutes per Week],
			    'Payer Buckets'[Payer Grouping]="(A) Medicare Part A and A-Like"
			)
		formatString: #,0
		displayFolder: Minutes
		lineageTag: 90e95855-c1c8-4228-a2b8-589d9d4e27ce

	measure 'Sel Unit' = SELECTEDVALUE('Unit of Analysis'[Unit], "Per Case")
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000001

	measure Volume =
			
			IF(
			    [Sel Unit] = "Per Track",
			    [Total Tracks],
			    [Total Cases]
			)
		formatString: #,0
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000002

	measure '% Improved' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE(CALCULATE([Total Tracks],FILTER(CaseTracks,[Gain]>0)),CALCULATE([Total Tracks],FILTER(CaseTracks,ISBLANK([Gain])=FALSE()))),
			    DIVIDE(CALCULATE([Total Cases],FILTER(StayCases,[Gain]>0)),CALCULATE([Total Cases],FILTER(StayCases,ISBLANK([Gain])=FALSE())))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000003

	measure '% Declined' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE(CALCULATE([Total Tracks],FILTER(CaseTracks,[Gain]<0)),CALCULATE([Total Tracks],FILTER(CaseTracks,ISBLANK([Gain])=FALSE()))),
			    DIVIDE(CALCULATE([Total Cases],FILTER(StayCases,[Gain]<0)),CALCULATE([Total Cases],FILTER(StayCases,ISBLANK([Gain])=FALSE())))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000004

	measure '% No Change' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE(CALCULATE([Total Tracks],FILTER(CaseTracks,[Gain]=0)),CALCULATE([Total Tracks],FILTER(CaseTracks,ISBLANK([Gain])=FALSE()))),
			    DIVIDE(CALCULATE([Total Cases],FILTER(StayCases,[Gain]=0)),CALCULATE([Total Cases],FILTER(StayCases,ISBLANK([Gain])=FALSE())))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000005

	measure '% Measured' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE(CALCULATE([Total Tracks],FILTER(CaseTracks,NOT(ISBLANK([Total Measurements Recorded])))),CALCULATE([Total Tracks],REMOVEFILTERS(Dictionary))),
			    DIVIDE(CALCULATE([Total Cases],FILTER(StayCases,NOT(ISBLANK([Total Measurements Recorded])))),CALCULATE([Total Cases],REMOVEFILTERS(Dictionary)))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000006

	measure '% Pain Improved' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE(CALCULATE([Total Tracks],FILTER(CaseTracks,[Gain (Pain)]>0)),CALCULATE([Total Tracks],FILTER(CaseTracks,[Admit Level (Pain)]<>1 && ISBLANK([Admit Level (Pain)])=FALSE()))),
			    DIVIDE(CALCULATE([Total Cases],FILTER(StayCases,[Gain (Pain)]>0)),CALCULATE([Total Cases],FILTER(StayCases,[Admit Level (Pain)]<>1 && ISBLANK([Admit Level (Pain)])=FALSE())))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000007

	measure 'Volume with Pain' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    CALCULATE([Total Tracks],FILTER(CaseTracks,[Admit Level (Pain)]<>1 && ISBLANK([Admit Level (Pain)])=FALSE())),
			    CALCULATE([Total Cases],FILTER(StayCases,[Admit Level (Pain)]<>1 && ISBLANK([Admit Level (Pain)])=FALSE()))
			)
		formatString: #,0
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000008

	measure 'Volume with Outcomes' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    CALCULATE([Total Tracks],FILTER(CaseTracks,[Total Measurements]>0)),
			    CALCULATE([Total Cases],FILTER(StayCases,[Total Measurements]>0))
			)
		formatString: #,0
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-000000000009

	measure 'Volume %' =
			
			IF(
			    [Sel Unit] = "Per Track",
			    DIVIDE([Total Tracks], CALCULATE([Total Tracks], ALLSELECTED(CaseTracks))),
			    DIVIDE([Total Cases], CALCULATE([Total Cases], ALLSELECTED(StayCases)))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit of Analysis
		lineageTag: 0a1b2c3d-0002-0002-0002-00000000000a

	partition MeasureTable = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation


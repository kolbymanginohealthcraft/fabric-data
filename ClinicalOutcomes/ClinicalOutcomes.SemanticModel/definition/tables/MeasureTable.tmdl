	measure Correlation = ```
			
			var _linest = 
			LINESTX(
			    StayCases,
			    [Gain],
			    [Minutes per Case]
			)
			
			
			var _correl = SELECTCOLUMNS(_linest,[CoefficientOfDetermination])
			return _correl
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 19fd416f-8921-42ae-9265-6fd742646456

	measure 'Correlation 2' =
			
			VAR __CORRELATION_TABLE = VALUES('StayCases'[PatientCase_ID])
			VAR __COUNT =
				COUNTX(
					KEEPFILTERS(__CORRELATION_TABLE),
					CALCULATE([Minutes per Case] * [Gain])
				)
			VAR __SUM_X = SUMX(KEEPFILTERS(__CORRELATION_TABLE), CALCULATE([Minutes per Case]))
			VAR __SUM_Y = SUMX(KEEPFILTERS(__CORRELATION_TABLE), CALCULATE([Gain]))
			VAR __SUM_XY =
				SUMX(
					KEEPFILTERS(__CORRELATION_TABLE),
					CALCULATE([Minutes per Case] * [Gain] * 1.)
				)
			VAR __SUM_X2 =
				SUMX(
					KEEPFILTERS(__CORRELATION_TABLE),
					CALCULATE([Minutes per Case] ^ 2)
				)
			VAR __SUM_Y2 = SUMX(KEEPFILTERS(__CORRELATION_TABLE), CALCULATE([Gain] ^ 2))
			RETURN
				(DIVIDE(
					__COUNT * __SUM_XY - __SUM_X * __SUM_Y * 1.,
					SQRT(
						(__COUNT * __SUM_X2 - __SUM_X ^ 2)
							* (__COUNT * __SUM_Y2 - __SUM_Y ^ 2)
					)
				))^2
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c492d6fc-1fa6-4b3f-a75b-a2d74c8012f5

		extendedProperty MeasureTemplate =
				{

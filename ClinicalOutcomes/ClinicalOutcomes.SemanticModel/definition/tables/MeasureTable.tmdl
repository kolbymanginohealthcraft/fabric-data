	measure 'ActiveFilters: Override' =
			
			var newline = UNICHAR(13)&UNICHAR(10)
			
			var overridedivision = IF(([Total Cases]<>[Total Cases BM] || ISFILTERED(VW_NHAegisFacilities[Division])),"Division(s): "&CONCATENATEX(VALUES(VW_NHAegisFacilities[Division]),VW_NHAegisFacilities[Division],", "))

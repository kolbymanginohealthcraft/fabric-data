table MeasureTable
	lineageTag: 81d3a9b3-47f2-40a4-a981-c24b4592eac3

	measure '% Improvement' =
			
			DIVIDE(
			    [Discharge Level]-[Admit Level],
			    [Admit Level]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 2f02235f-cc18-4fe4-8392-db420421a617

	measure '% Improvement BM' =
			
			DIVIDE(
			    [Discharge Level BM]-[Admit Level BM],
			    [Admit Level BM]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: c1cb8bc9-9e90-4967-b6a2-37665748f12b

	measure '% Improvement Delta' = IF([Report Scope]="Filtered",[% Improvement]-[% Improvement BM])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 5b57d1d8-e3dc-44df-88da-7d42102a15d7

	measure Gain = [Discharge Level]-[Admit Level]
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: aba5c6a3-5359-4cd3-837d-e67eee3f6fd7

	measure 'Gain BM' = [Discharge Level BM]-[Admit Level BM]
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: ec8b2cd5-4731-46be-b85f-346fe0a16cef

	measure 'Gain Delta' = IF([Report Scope]="Filtered",[Gain]-[Gain BM])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 929d3709-0479-4d7b-a543-668aa4318481

	measure 'Discharge Level' =
			
			// CALCULATE(
			//     AVERAGE(OutcomeSummary[TableDisch]),
			//     OR(
			//         OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763} && OutcomeSummary[Criteria] IN {"Included" ,"Started with ANA 88", "No start score"},
			//         NOT(OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763}) && OutcomeSummary[Criteria] IN {"Included"}
			//     )
			// )
			
			CALCULATE(
			    AVERAGE(OutcomeSummary[TableDisch]),
			    OutcomeSummary[Status]="Included"
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 3bf84c2d-11e2-41b7-81ee-227199aabc6f

	measure 'Discharge Level BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Discharge Level],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 578e61fc-3159-409f-ad6f-06fe45d9c2a5

	measure 'Admit Level' =
			
			CALCULATE(
			    AVERAGE(OutcomeSummary[EvalNEW]),
			    OutcomeSummary[Status]="Included"
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: c4ca960c-91fe-44b6-a9c8-46edcfd51e7a

	measure 'Admit Level BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Admit Level],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: bb5470a8-0b8e-4ce5-adeb-46039c62115d

	measure 'Total Measurements' =
			
			// CALCULATE(
			//     COUNTROWS(OutcomeSummary),
			//     OR(
			//         OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763} && OutcomeSummary[Criteria] IN {"Included" ,"Started with ANA 88", "No start score"},
			//         NOT(OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763}) && OutcomeSummary[Criteria] IN {"Included"}
			//     )
			// )
			
			CALCULATE(
			    [Total Measurements Recorded],
			    OutcomeSummary[Status]="Included"
			)
		formatString: #,0
		displayFolder: Outcomes
		lineageTag: a5932dd1-21c8-403a-a991-c4d9f6e89cf4

	measure 'Total Outcome Areas Unique' =
			
			// CALCULATE(
			//     DISTINCTCOUNT(Dictionary[Name]),
			//     OR(
			//         OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763} && OutcomeSummary[Criteria] IN {"Included" ,"Started with ANA 88", "No start score"},
			//         NOT(OutcomeSummary[LibraryItem_ID] IN {7764,7765,7766,7760,7761,7762,7763}) && OutcomeSummary[Criteria] IN {"Included"}
			//     )
			// )
			
			CALCULATE(
			    DISTINCTCOUNT(Dictionary[Name]),
			    OutcomeSummary[Status]="Included"
			)
		formatString: 0
		displayFolder: Outcomes
		lineageTag: 35717f59-d6c6-478a-8650-fade06168e18

	measure 'Total Outcome Areas Subtitle' = [Total Outcome Areas Unique]&" areas measured"
		displayFolder: Outcomes
		lineageTag: ffbf6c01-02ca-40b0-9d0a-7802a5f54ffb

	measure ALOS =
			
			DIVIDE(
			    [Total Days],
			    [Total Cases]
			)
		formatString: #,0.0
		displayFolder: ALOS
		lineageTag: 630298d4-6fa8-4095-a83c-c6e6f4033dbc

	measure 'ALOS BM' =
			
			// CALCULATE(
			//     [ALOS],
			//     BenchmarkTable[BenchmarkSetting] = "Benchmark"
			// )
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [ALOS],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0
		displayFolder: ALOS
		lineageTag: 3d34b86d-327c-4aa5-b48d-754baa3af1ed

	measure 'ALOS Delta' =
			
			// [ALOS]-[ALOS BM]
			IF([Report Scope]="Filtered",[ALOS]-[ALOS BM])
		formatString: 0.0
		displayFolder: ALOS
		lineageTag: 5bddd9bd-8c53-4f48-a1c7-49a8a7fad294

	measure '% Total Cases Improved' =
			
			DIVIDE(
			    CALCULATE([Total Cases],FILTER(StayCases,[Gain]>0)),
			    CALCULATE([Total Cases],FILTER(StayCases,ISBLANK([Gain])=FALSE()))
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 2009c7d3-34a0-4538-aa16-e9062a9490f2

	measure '% Total Cases Improved BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [% Total Cases Improved],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: 402f5ea2-942d-4469-90f7-fd01c7cb7704

	measure '% Total Cases Improved Delta' = IF([Report Scope]="Filtered",[% Total Cases Improved]-[% Total Cases Improved BM])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Outcomes
		lineageTag: ec8329b4-d253-42ef-bb4a-42f6dfae30ae

	measure DTC =
			
			DIVIDE(
			    CALCULATE([Total Cases],DischargeDestination[Group] = "Community"),
			    CALCULATE([Total Cases],DischargeDestination[Type] <> "Unknown")
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: c0c4a183-0f59-487e-b863-419b6f2a549c

	measure 'DTC BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [DTC],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: 45d83007-8003-4ebe-b97d-223b60a8c4c6

	measure 'DTC Delta' =
			
			// [DTC]-[DTC BM]
			
			// IF(
			//     NOT(SELECTEDVALUE(BenchmarkTable[BenchmarkSetting])="Benchmark"),
			//     [DTC]-[DTC BM]
			// )
			
			IF([Report Scope]="Filtered",[DTC]-[DTC BM])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: 8db3087d-bd46-46ce-affa-f0e248dbba17

	measure Rehosp =
			
			DIVIDE(
			    CALCULATE([Total Cases],FILTER(DischargeDestination,DischargeDestination[Setting] = "Hospital")),
			    CALCULATE([Total Cases],DischargeDestination[Type] <> "Unknown")
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: e558747b-e8ad-4732-88c7-26c7276228bf

	measure 'Rehosp BM' =
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Rehosp],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: 3462e0ab-55d8-41af-b9fa-2a62d3651861

	measure 'Rehosp Delta' = IF([Report Scope]="Filtered",[Rehosp]-[Rehosp BM])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Discharge Destination
		lineageTag: 282d3e79-b3b2-44ef-ad36-cf1dd42741d8

	measure 'Total Units' = SUM(TreatmentsDetails[Units])
		formatString: #,0
		displayFolder: Units
		lineageTag: 041af93e-4596-43f7-be46-2b3b9acbf6ea

	measure 'Units per Visit (pt/ot)' =
			
			// IF([Total Cases All Payers]>0,
			// CALCULATE(
			//     DIVIDE(
			//         [Total Units],
			//         [Total Visits]
			//     ),
			//     Disciplines[Discipline] IN {"PT", "OT"}
			// ))
			
			CALCULATE(
			    DIVIDE(
			        [Total Units],
			        [Total Visits]
			    ),
			    Disciplines[Discipline] IN {"PT", "OT"}
			)
		formatString: 0.00
		displayFolder: Units
		lineageTag: 53b2f234-8bb4-425b-af53-c885887b0e79

	measure 'Units per Visit BM' =
			
			// CALCULATE(
			//     [Units per Visit (pt/ot)],
			//     BenchmarkTable[BenchmarkSetting] = "Benchmark"
			// )
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Units per Visit (pt/ot)],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.00
		displayFolder: Units
		lineageTag: de8a866b-2505-4ec3-931f-8f946ba5fe3a

	measure 'Units per Visit Delta' =
			
			// [Units per Visit (pt/ot)]-[Units per Visit BM]
			IF([Report Scope]="Filtered",[Units per Visit (pt/ot)]-[Units per Visit BM])
		formatString: 0.00
		displayFolder: Units
		lineageTag: 72ef3f37-c58a-43e0-831e-494f9cc6ddb8

	measure 'Minutes per Case' =
			
			DIVIDE(
			    [Total Minutes],
			    [Total Cases]
			)
		formatString: #,0
		displayFolder: Minutes
		lineageTag: 09ca9c98-9580-4994-8ccc-86a868cd0fb7

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Minutes per Code' = AVERAGE(TreatmentsDetails[Duration])
		displayFolder: Minutes
		lineageTag: 09b59067-ec3b-4429-81b1-6ee518c45303

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Minutes per Unit' = [Total Minutes]/[Total Units]
		displayFolder: Minutes
		lineageTag: d8c992c1-5536-4d67-a686-8e7550ad81ee

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Minutes per Visit' =
			
			DIVIDE(
			    [Total Minutes],
			    [Total Visits]
			)
		displayFolder: Minutes
		lineageTag: 7f234f4c-fab9-420d-88b0-43f471d3c32b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Minutes per Week' =
			
			DIVIDE(
			    [Total Minutes],
			    [Total Days]
			)*7
		formatString: #,0
		displayFolder: Minutes
		lineageTag: c69eb433-9ea3-4846-8162-e08312d65158

	measure 'Minutes per Week BM' =
			
			// CALCULATE(
			//     [Minutes per Week],
			//     BenchmarkTable[BenchmarkSetting] = "Benchmark"
			// )
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Minutes per Week],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: #,0
		displayFolder: Minutes
		lineageTag: 46e96f44-608f-452a-901b-29c64aa1503b

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Minutes Variance' =
			
			STDEVX.P(
			    KEEPFILTERS(VALUES(StayCases[PatientCase_ID])),
			    CALCULATE([Minutes per Week])
			)
		formatString: #,0
		displayFolder: Minutes
		lineageTag: d07b96eb-63ae-4cfc-9932-686dc4e7d7bf

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Total Minutes' = SUM(TreatmentsDetails[Duration])
		formatString: #,0
		displayFolder: Minutes
		lineageTag: 9150bd80-028f-4835-b56d-4f57923a42eb

	measure 'Total Days with Visits' = DISTINCTCOUNT(Treatments[CaseIDDate])
		formatString: #,0
		displayFolder: Visits
		lineageTag: 3736d65f-010b-4cef-b6a1-812476178245

	measure 'Total Visits' = COUNTROWS(Treatments)
		formatString: #,0
		displayFolder: Visits
		lineageTag: a7244d21-36e1-4319-a650-3808c07d4b02

	measure 'Visits per Discipline per Week' =
			
			// AVERAGEX(
			//     FILTER(StayCases,[Total Days]>=7),
			//     DIVIDE(
			//         DIVIDE(
			//             [Total Visits],
			//             [Total Days]
			//         )*7,
			//         [Total Disciplines]
			//     )
			// )
			
			// AVERAGEX(
			//     StayCases,
			//     DIVIDE(
			//         DIVIDE(
			//             [Total Visits],
			//             [Total Days]
			//         )*7,
			//         [Total Disciplines]
			//     )
			// )
			
			AVERAGEX(
			    StayCases,
			    DIVIDE(
			        [Visits per Week],
			        [Total Disciplines Unique]
			    )
			)
		formatString: 0.00
		displayFolder: Visits
		lineageTag: 2073f7b4-5040-4bbd-b36b-f70c5b1056e7

	measure 'Visits per Discipline per Week BM' =
			
			// CALCULATE(
			//     [Visits per Discipline per Week],
			//     BenchmarkTable[BenchmarkSetting] = "Benchmark"
			// )
			
			IF([Report Scope]="Filtered",
			CALCULATE(
			    [Visits per Discipline per Week],
			    BenchmarkTable[BenchmarkSetting] = "Benchmark"
			))
		formatString: 0.00
		displayFolder: Visits
		lineageTag: e25c035d-b5cd-4d55-812d-83c0b6aad355

	measure 'Visits per Discipline per Week Delta' =
			
			// [Visits per Discipline per Week]-[Visits per Discipline per Week BM]
			IF([Report Scope]="Filtered",[Visits per Discipline per Week]-[Visits per Discipline per Week BM])
		formatString: 0.00
		displayFolder: Visits
		lineageTag: 7813a48b-ce90-462b-ae0b-dcea35aa8371

	measure '% Improvement AxisLow' =
			
			var range = [% Improvement BM]-[% Improvement]
			var extendedrange = range/.8
			var incrementalrange = (extendedrange-range)/2
			var calc = MIN(0,[% Improvement])-incrementalrange
			return IF([% Improvement]<0,calc,0)
		displayFolder: Outcomes
		lineageTag: 7437af67-348b-413a-a09c-94123acc108d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Improvement AxisHigh' =
			
			var range = [% Improvement]
			var extendedrange = range/.8
			var incrementalrange = (extendedrange-range)/2
			var calc = MAX([% Improvement],[% Improvement BM])+incrementalrange
			return IF([% Improvement]>[% Improvement BM]-.1,calc,[% Improvement BM])
		displayFolder: Outcomes
		lineageTag: 1d70399f-f6cd-42cd-be10-1b191c38ddcf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Minutes per Week Percentile' =
			
			var myvalue = [Minutes per Week]
			return
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(
			            FILTER(
			                StayCases,
			                [Minutes per Week]<myvalue
			            )
			        ),
			        ALLSELECTED(StayCases[PatientCase_ID]),
			        ALL(StayCases[PatientCase_ID]),
			        ALL(vw_UpnFacilityAccess)
			    ),
			    [Total Cases BM]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Minutes
		lineageTag: 4e8e6106-3831-4209-a850-33a16d2d122e

	measure 'Minutes per Week Percentile Text' =
			
			"Provider avg minutes = "&FORMAT([Minutes per Week],"#,###")&"; Percentile = "&FORMAT([Minutes per Week Percentile],"0%")
		displayFolder: Minutes
		lineageTag: 9378e808-51d2-4584-a01f-8587cc9bfccc

	measure 'Total Cases' =
			
			var v1 = COUNTROWS(StayCases)
			var v2 = CALCULATE(COUNTROWS(StayCases),FILTER(StayCases,[Total Tracks]>0))
			return v2
		formatString: #,0
		displayFolder: Cases
		lineageTag: 77a0d69a-1460-4d25-b7e1-774421d4d8a6

	measure 'Total Cases All Payers' =
			
			CALCULATE(
			    [Total Cases],
			    ALL(StayCases[Payer Categorization])
			)
		formatString: #,0
		displayFolder: Cases
		lineageTag: e10db99f-6d15-41b2-a2b8-31d29896fbce

	measure 'Total Cases BM' =
			
			CALCULATE(
			    [Total Cases],
			    BenchmarkTable[BenchmarkSetting]="Benchmark"
			)
		formatString: #,0
		displayFolder: Cases
		lineageTag: b43fba77-6414-4b70-bca7-d21b2523d080

	measure 'Drill Button Text' =
			
			IF(
			    HASONEVALUE(StayCases[PatientCase_ID])=FALSE(),
			    "<<Please select a single episode from the table below, and then click this button>>",
			    "Show details for "&SELECTEDVALUE(Patients[Patient Name])
			)
		displayFolder: Outcomes
		lineageTag: 20866bb4-7c4b-4705-bdff-9fddc4becd12

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Admit Level Jitter' = MIN(ABS([Admit Level] + IF(RAND()>.5,1,-1)*RAND()/500),1)
		formatString: 0%;-0%;0%
		displayFolder: Outcomes
		lineageTag: 2ca55427-5fc7-4ee1-a849-722f63c414aa

	measure 'Discharge Level Jitter' = MIN(ABS([Discharge Level] + IF(RAND()>.5,1,-1)*RAND()/500),1)
		formatString: 0%;-0%;0%
		displayFolder: Outcomes
		lineageTag: 16b865d5-280e-4efd-a2f8-8ca5e45c590e

	measure 'Admit Level (Pain)' =
			
			CALCULATE(
			    [Admit Level],
			    Dictionary[Group]="Pain"
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Pain
		lineageTag: f5c5913d-751b-48f1-8a36-de79f73a57c0

	measure 'Discharge Level (Pain)' =
			
			CALCULATE(
			    [Discharge Level],
			    Dictionary[Group]="Pain"
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Pain
		lineageTag: 952398a8-568a-4100-bee9-ecd7709f2445

	measure '% Improvement (Pain)' =
			
			IF([Total Cases All Payers]>0,
			    DIVIDE(
			        [Discharge Level (Pain)]-[Admit Level (Pain)],
			        [Admit Level (Pain)]
			    )+.00001
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Pain
		lineageTag: e5424d15-57ce-4875-ba21-d14b1f8070ad

	measure '% Minutes Group Therapy' =
			
			DIVIDE(
			    [Total Minutes Group Therapy],
			    [Total Minutes]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Group Therapy
		lineageTag: b7270072-775e-414d-870d-f9f955796237

	measure '% Minutes Group Therapy Text' =
			
			FORMAT(
			    [% Minutes Group Therapy]+0,
			    "0.0%"
			)
			&" group minutes"
		displayFolder: Group Therapy
		lineageTag: 23bb5e0a-9f90-459d-93d0-480e842bce98

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Visits Group Therapy' =
			
			DIVIDE(
			    [Total Visits Group Therapy],
			    [Total Visits]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Group Therapy
		lineageTag: 0b055e89-10ca-4348-8df3-430284117bd5

	measure '% Minutes Telehealth' =
			
			DIVIDE(
			    [Total Minutes Telehealth],
			    [Total Minutes]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Telehealth
		lineageTag: 51642e05-f654-4bf5-9457-221a3755e662

	measure '% Visits Telehealth' =
			
			DIVIDE(
			    [Total Visits Telehealth],
			    [Total Visits]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Telehealth
		lineageTag: 38b56051-652e-4ce2-b5a6-abae358de27e

	measure '% Minutes Modalities' =
			
			DIVIDE(
			    [Total Minutes Modalities],
			    [Total Minutes]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Modalities
		lineageTag: 150e6b1a-2b17-4259-b7c4-cc9d464f9914

	measure '% Visits Modalities' =
			
			DIVIDE(
			    [Total Visits Modalities],
			    [Total Visits]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Modalities
		lineageTag: 980309bb-2df9-4935-a24f-b3b827b5c438

	measure '% Minutes Aquatic' =
			
			DIVIDE(
			    [Total Minutes Aquatic],
			    [Total Minutes]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Aquatic
		lineageTag: a7ed64f1-2aab-4fcf-9d1a-c6095f9ca25d

	measure '% Visits Aquatic' =
			
			DIVIDE(
			    [Total Visits Aquatic],
			    [Total Visits]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Aquatic
		lineageTag: ee74d04f-9aa0-4fbb-b5ff-dd154bd485c9

	measure 'Total Units Aquatic' =
			
			CALCULATE(
			    [Total Units],
			    Service[Specialty]="Aquatic"
			)

/// Outcome-library dimension. Maps each LibraryItem_ID to its NetHealth
/// VersionName and the collapsed SNF/OP Library (the eval cohort's "Library"
/// axis). Library rule mirrors the therapist-evaluation pipeline exactly:
/// OP = VersionName LIKE '%OP%' OR '%GP%' (OP2025.5, GP2022.01); else SNF.
/// Sourced from the patient lakehouse (NetHealthDocumentation.LibraryItem),
/// keyed on LibraryItem_ID, related to OutcomeSummary so outcomes can be
/// sliced/cohorted by SNF vs OP library. (Replaces the old dataflow LibraryItem
/// table, which carried Caption/Section junk but NOT VersionName.)
table LibraryItem
	lineageTag: 11b10000-0000-4000-8000-000000000001

	column LibraryItem_ID
		dataType: int64
		isKey
		formatString: 0
		lineageTag: 11b10000-0000-4000-8000-000000000002
		summarizeBy: none
		sourceColumn: LibraryItem_ID

		annotation SummarizationSetBy = Automatic

	column VersionName
		dataType: string
		lineageTag: 11b10000-0000-4000-8000-000000000003
		summarizeBy: none
		sourceColumn: VersionName

		annotation SummarizationSetBy = Automatic

	column Library
		dataType: string
		lineageTag: 11b10000-0000-4000-8000-000000000004
		summarizeBy: none
		sourceColumn: Library

		annotation SummarizationSetBy = Automatic

	partition LibraryItem = m
		mode: import
		queryGroup: Outcomes
		source =
				let
				    Source = Value.NativeQuery(_AegisPatient, "SELECT LibraryItem_ID, VersionName, CASE WHEN VersionName LIKE '%OP%' OR VersionName LIKE '%GP%' THEN 'OP' ELSE 'SNF' END AS Library FROM NetHealthDocumentation.LibraryItem WHERE LibraryItem_ID IS NOT NULL")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

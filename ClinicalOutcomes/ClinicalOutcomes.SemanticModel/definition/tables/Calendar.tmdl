		lineageTag: e7faf6d1-d0e5-400d-9ac2-2dee65a5a3cf
		summarizeBy: none
		isNameInferred
		sourceColumn: [Week Start Date]

		annotation SummarizationSetBy = Automatic

	column Quarter
		lineageTag: 09fcc546-6821-4dd7-8163-6d5143f634de
		summarizeBy: none
		isNameInferred
		sourceColumn: [Quarter]

		annotation SummarizationSetBy = Automatic

	column Month
		formatString: 0
		lineageTag: 9aff7e1d-af3a-4462-95dd-6ce5be3edb9a
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month]

		annotation SummarizationSetBy = Automatic

	column ReliableScope =
			
			// DATE(YEAR(TODAY())-1,MONTH(TODAY()),1)<='Calendar'[Date]
			
			'Calendar'[Date] >= DATE(YEAR(TODAY())-1,MONTH(TODAY()),1)
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: ee2c5621-a5f8-4426-9772-775d41be5d3b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column YearWeek
		lineageTag: 1af5412d-7a14-4c33-9771-179176a96ff7
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearWeek]

		annotation SummarizationSetBy = Automatic

	hierarchy 'Date Hierarchy'
		lineageTag: 56d1a6a9-d369-4775-bac6-02a6ee7ff7ab

		level Year
			lineageTag: e84af10c-9a75-46d2-a416-bacebf7097fa
			column: Year

		level Quarter
			lineageTag: 1b1ce00d-3b52-4420-907c-3b35b7c373b7
			column: Quarter

		level Month
			lineageTag: afd4801c-9199-4f04-bc5b-0378ef58da74
			column: Month

		level Day
			lineageTag: 69b29c97-a7b8-4486-814b-740abba88a5e
			column: Day

		level Date
			lineageTag: 20865bee-4cba-4949-8884-926fc56f1355
			column: Date

	partition Calendar = calculated
		mode: directQuery
		source =
				
				ADDCOLUMNS(
				    // CALENDAR(DATE(YEAR(TODAY())-1,MONTH(TODAY()),1),TODAY()),
				    CALENDAR("1/1/2020",TODAY()-1),
				    "Year",YEAR([Date]),
				    "Quarter","Qtr "&QUARTER([Date]),
				    "Month",MONTH([Date]),
				    "Day",DAY([Date]),
				    "Week Number",WEEKNUM([Date]),
				    "Week Day",WEEKDAY([Date]),
				    "Week Start Date",[Date]-WEEKDAY([Date],1)+1,
				    "Day Name",FORMAT([Date],"ddd"),
				    "YearQuarter",YEAR([Date])&"-Q"&QUARTER([Date]),
				    "YearMonth",YEAR([Date])&"-"&FORMAT(MONTH([Date]),"00"),
				    "YearWeek",YEAR([Date])&"-"&FORMAT(WEEKNUM([Date]),"00")
				)

	annotation PBI_Id = 5fe0dcb260d049c2a80dc56f513d2515


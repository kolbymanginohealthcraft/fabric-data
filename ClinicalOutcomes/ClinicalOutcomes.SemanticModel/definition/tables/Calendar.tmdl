		sourceColumn: [Week Day]

		annotation SummarizationSetBy = Automatic

	column Day
		formatString: 0
		lineageTag: 03317bd0-da69-4816-bc96-204f4cc80d09
		summarizeBy: none
		isNameInferred
		sourceColumn: [Day]

		annotation SummarizationSetBy = Automatic

	column 'Day Name'
		lineageTag: 8c002178-e217-4b52-bd4d-8cbbe4b2781f
		summarizeBy: none

table Calendar
	lineageTag: 74314849-39dd-40d3-9386-e3ea04963081
	dataCategory: Time

	measure 'Today''s Date' = TODAY()
		formatString: Short Date
		lineageTag: 5ab381dd-055a-4ab4-96c7-249b1362130a

	measure Timeframe =
			
			// "Timeframe: "&
			FORMAT(MIN('Calendar'[Date]),"mm/dd/yyyy")&" - "&FORMAT(MAX('Calendar'[Date]),"mm/dd/yyyy")
		lineageTag: f5244a50-7366-4bff-bff8-c0ae004d7a57

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeframe for Patient View' =
			
			MIN(StayCases[TherapyStartDate])&" - "&MAX(StayCases[TherapyEndDate])&
			IF(
			    [Total Cases] > 1,
			    " ("&FORMAT([Total Cases],"#,###")&" cases)"
			)
		lineageTag: b5f2c2d4-842b-49bb-b5bf-d95bcdd9b4b7

	measure 'Total Calendar Days' =
			
			COUNTROWS('Calendar')
		lineageTag: 5faa05fe-8e31-4747-a19d-9d9083bf3a2b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Report Date' =
			
			// "Report Date: "&
			FORMAT(TODAY(),"mm/dd/yyyy")
		lineageTag: 81a30952-696e-40c6-89c2-2d302e31359b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Date
		isKey
		formatString: Short Date
		lineageTag: c58aea1b-7332-4d18-8225-97ea0afa8818
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	column YearMonth
		lineageTag: 2110138b-1955-4ffe-a6d6-7f0bef4a498d
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearMonth]

		annotation SummarizationSetBy = Automatic

	column YearQuarter
		lineageTag: fac55edc-3edf-49ae-9459-d9ad8d221494
		summarizeBy: none
		isNameInferred
		sourceColumn: [YearQuarter]

		annotation SummarizationSetBy = Automatic

	column Year
		formatString: 0
		lineageTag: f3234a53-2084-4e74-9ebd-cf3f97652e02
		summarizeBy: none
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column 'Week Number'
		formatString: 0
		lineageTag: 11328bc1-6ffd-47d3-a28f-06aa2d41a9bb
		summarizeBy: none
		isNameInferred
		sourceColumn: [Week Number]

		annotation SummarizationSetBy = Automatic


	measure GanttChartSVG = ```
			
			VAR StartDate = SELECTEDVALUE(StayCases[TherapyStartDate]) // Replace with the earliest date in your data
			VAR EndDate = [Timeline End] // Replace with the earliest date in your data
			VAR ChartWidth = 500 // Width of the entire SVG chart
			VAR ChartHeight = 300 // Height of the entire SVG chart
			VAR BarHeight = 30 // Height of each therapy bar
			VAR BarSpacing = 10 // Spacing between therapy bars
			VAR VisitMarkerSize = 5 // Size of each visit marker (e.g., line or circle)
			
			VAR BarsPT = 
			    CONCATENATEX(
			        VALUES(Disciplines[Ordered Discipline]),
			        VAR Therapy = Disciplines[Ordered Discipline]
			        VAR StartX = DATEDIFF(StartDate,MINX(FILTER(CaseTracks, Disciplines[Ordered Discipline] = Therapy), CaseTracks[StartDate]), DAY) 
			                    * ChartWidth / DATEDIFF(StartDate, MAX(CaseTracks[EndDate]), DAY)
			        VAR EndX = DATEDIFF(StartDate,MAXX(FILTER(CaseTracks, Disciplines[Ordered Discipline] = Therapy), CaseTracks[EndDate]), DAY) 
			                  * ChartWidth / DATEDIFF(StartDate, MAX(CaseTracks[EndDate]), DAY)
			        VAR BarY = (RANKX(ALL(Disciplines[Ordered Discipline]), Therapy) - 1) * (BarHeight + BarSpacing)
			        RETURN 
			            "<rect 
			                x=""" & StartX & """ 
			                y=""" & BarY & """ 
			                width=""" & (EndX - StartX) & """ 
			                height=""" & BarHeight & """ 
			                fill=""#3DB3E3"" 
			                fill-opacity=""0.25"" 
			                stroke=""#3DB3E3"" 
			                stroke-opacity=""0.10""
			            />"
			    )
			
			VAR BarsOT = 
			    CONCATENATEX(
			        VALUES(Disciplines[Ordered Discipline]),
			        VAR Therapy = Disciplines[Ordered Discipline]
			        VAR StartX = DATEDIFF(StartDate,MINX(FILTER(CaseTracks, Disciplines[Ordered Discipline] = Therapy), CaseTracks[StartDate]), DAY) 
			                    * ChartWidth / DATEDIFF(StartDate, MAX(CaseTracks[EndDate]), DAY)
			        VAR EndX = DATEDIFF(StartDate,MAXX(FILTER(CaseTracks, Disciplines[Ordered Discipline] = Therapy), CaseTracks[EndDate]), DAY) 
			                  * ChartWidth / DATEDIFF(StartDate, MAX(CaseTracks[EndDate]), DAY)
			        VAR BarY = (RANKX(ALL(Disciplines[Ordered Discipline]), Therapy) - 1) * (BarHeight + BarSpacing)
			        RETURN 
			            "<rect 
			                x=""" & StartX+BarHeight & """ 
			                y=""" & BarY & """ 
			                width=""" & (EndX - StartX) & """ 
			                height=""" & BarHeight & """ 
			                fill=""#3DB3E3"" 
			                fill-opacity=""0.25"" 
			                stroke=""#3DB3E3"" 
			                stroke-opacity=""0.10""
			            />"
			    )
			
			VAR VisitMarkers = 
			    CONCATENATEX(
			        VALUES(Treatments[LaborDate]),
			        VAR VisitX = DATEDIFF(Treatments[LaborDate], StartDate, DAY) 
			                     * ChartWidth / DATEDIFF(StartDate, MAX(CaseTracks[EndDate]), DAY)
			        VAR Therapy = SELECTEDVALUE(Disciplines[Ordered Discipline])
			        VAR BarY = (RANKX(ALL(Disciplines[Ordered Discipline]), Therapy) - 1) * (BarHeight + BarSpacing)
			        RETURN 
			            "<line 
			                x1=""" & VisitX & """ 
			                x2=""" & VisitX & """ 
			                y1=""" & BarY & """ 
			                y2=""" & (BarY + BarHeight) & """ 
			                stroke=""#3DB3E3"" 
			                stroke-width=""2"" 
			            />"
			    )
			
			RETURN 
			    // "data:image/svg+xml;utf8,<svg width=""" & ChartWidth & """ height=""" & ChartHeight & """>" & Bars & VisitMarkers & "</svg>"
			    "data:image/svg+xml;utf8,<svg width="""&ChartWidth&""" height="""&ChartHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			    BarsPT&
			    BarsOT&
			    VisitMarkers&
			    "</svg>"
			```
		lineageTag: 777d0880-632c-4319-8879-5735aeb06223
		dataCategory: ImageUrl

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeline SVG 2' = ```
			
			
			var canvasWidth = 700
			var canvasHeight = 100
			var caseStart = [Case Start]
			var caseEnd = [Case End]
			var leftPad = .02
			var rightPad = 1-leftPad
			var topPad = .02
			var barSpacing = 5
			var barHeight = canvasHeight/(3+4*barSpacing)
			
			
			return
			//prefix
			"data:image/svg+xml;utf8,<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//case start
			"<line x1="""&leftPad*canvasWidth&""" x2="""&leftPad*canvasWidth&"""  y1="""&topPad*canvasHeight&""" y2="""&"152"&""" 
			stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//case end
			"<line x1="""&"668.75"&""" x2="""&"668.75"&""" y1="""&"0"&""" y2="""&"152"&""" 
			stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//boxPT
			"<rect x=""1"" y=""1"" width=""268"" height=""28"" fill=""#0C436A"" fill-opacity=""0.3"" stroke=""#0C436A"" stroke-opacity=""0.8""/>"&
			
			//boxOT (2)
			"<rect x=""43"" y=""71"" width=""268"" height=""28"" fill=""#0C436A"" fill-opacity=""0.3"" stroke=""#0C436A"" stroke-opacity=""0.8""/>"&
			"<rect x=""350"" y=""71"" width=""268"" height=""28"" fill=""#0C436A"" fill-opacity=""0.3"" stroke=""#0C436A"" stroke-opacity=""0.8""/>"&
			
			//boxST
			"<rect x=""162"" y=""36"" width=""268"" height=""28"" fill=""#0C436A"" fill-opacity=""0.3"" stroke=""#0C436A"" stroke-opacity=""0.8""/>"&
			
			//visits
			"<line x1=""7.75"" y1=""5"" x2=""7.75"" y2=""24"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			"<line x1=""168.75"" y1=""40"" x2=""168.75"" y2=""59"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			"<line x1=""387.75"" y1=""75"" x2=""387.75"" y2=""94"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			"<line x1=""25.75"" y1=""5"" x2=""25.75"" y2=""24"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			"<line x1=""50.75"" y1=""5"" x2=""50.75"" y2=""24"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			"<line x1=""15.75"" y1=""5"" x2=""15.75"" y2=""24"" stroke=""#0C436A"" stroke-width=""1.5""/>"&
			
			//suffix
			"</svg>"
			```
		lineageTag: f705b05e-485c-4ab1-bbd3-eaece8e46a74
		dataCategory: ImageUrl

		annotation PBI_FormatHint = {"isGeneralNumber":true}


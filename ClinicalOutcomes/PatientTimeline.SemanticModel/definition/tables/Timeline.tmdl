	partition Timeline = calculated
		mode: import
		source = ```
				
				VAR cutoff = EDATE ( TODAY (), -24 ) + 1
				VAR base =
				    FILTER (
				        UNION (
				        //---------------------------------------
				        // RESIDENCE (PatientStays -> IntakeSources)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            PatientStays,
				            "PatientID",  PatientStays[PatientID],
				            "ItemID",     PatientStays[Stay_ID],
				            "EventType",  "Residence",
				            "LaneGroup",  "02|Residence",
				            "Lane",       "02|Residence",
				            "Item",       "Residence",
				            "Detail",     COALESCE ( RELATED ( IntakeSources[Abbrev] ), "Unknown" ),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      PatientStays[AdmitDate],
				            "End",
				                VAR pid = PatientStays[PatientID]
				                VAR maxOtherDate =
				                    MAXX (
				                        UNION (
				                            // stays
				                            SELECTCOLUMNS (
				                                FILTER ( PatientStays, PatientStays[PatientID] = pid ),
				                                "d", COALESCE ( PatientStays[DischargeDate], PatientStays[AdmitDate] )
				                            ),
				                            // cases
				                            SELECTCOLUMNS (
				                                FILTER ( StayCases, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", StayCases[TherapyEndDate]
				                            ),
				                            // payers
				                            SELECTCOLUMNS (
				                                FILTER ( vw_PatientPayers, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", vw_PatientPayers[ThruDate]
				                            ),
				                            // tracks
				                            SELECTCOLUMNS (
				                                FILTER ( CaseTracks, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", CaseTracks[EndDate]
				                            ),
				                            // visits
				                            SELECTCOLUMNS (
				                                FILTER ( Treatments, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", Treatments[LaborDate]
				                            ),
				                            // PLOS items
				                            SELECTCOLUMNS (
				                                FILTER ( PatientLevelOptionalServices_Instance, RELATED ( Patients[PatientID] ) = pid ),
				                                "d", PatientLevelOptionalServices_Instance[CreatedDate]
				                            ),
				                            // screens (PatientScreens)
				                            SELECTCOLUMNS (
				                                FILTER ( PatientScreens, PatientScreens[Resolved PatientID] = pid ),
				                                "d", PatientScreens[DateCompleted]
				                            )
				                        ),
				                        [d]
				                    )
				                RETURN
				                    COALESCE (
				                        PatientStays[DischargeDate],
				                        maxOtherDate + 1,
				                        PatientStays[AdmitDate] + 1
				                    )
				        ),
				
				        //---------------------------------------
				        // PAYERS (vw_PatientPayers -> PatientStays)  ? moved above Stay
				        //---------------------------------------
				        SELECTCOLUMNS (
				            vw_PatientPayers,
				            "PatientID",  RELATED ( PatientStays[PatientID] ),
				            "ItemID",     vw_PatientPayers[Payer_ID],
				            "EventType",  "Payer",
				            "LaneGroup",  "03|Payer",
				            "Lane",       "03|Payer",
				            "Item",       "Payer",
				            "Detail",     RIGHT ( vw_PatientPayers[Payer Group], LEN ( vw_PatientPayers[Payer Group] ) - 4 ),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      vw_PatientPayers[FromDate],
				            "End",        vw_PatientPayers[ThruDate]
				        ),
				
				        //---------------------------------------
				        // STAY (PatientStays as its own line item) ? now after Payer
				        //---------------------------------------
				        SELECTCOLUMNS (
				            PatientStays,
				            "PatientID",  PatientStays[PatientID],
				            "ItemID",     PatientStays[Stay_ID],
				            "EventType",  "Stay",
				            "LaneGroup",  "04|Stay",
				            "Lane",       "04|Stay",
				            "Item",       "Stay",
				            "Detail",     BLANK (),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      PatientStays[AdmitDate],
				            "End",
				                VAR pid = PatientStays[PatientID]
				                VAR maxOtherDate =
				                    MAXX (
				                        UNION (
				                            // stays
				                            SELECTCOLUMNS (
				                                FILTER ( PatientStays, PatientStays[PatientID] = pid ),
				                                "d", COALESCE ( PatientStays[DischargeDate], PatientStays[AdmitDate] )
				                            ),
				                            // cases
				                            SELECTCOLUMNS (
				                                FILTER ( StayCases, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", StayCases[TherapyEndDate]
				                            ),
				                            // payers
				                            SELECTCOLUMNS (
				                                FILTER ( vw_PatientPayers, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", vw_PatientPayers[ThruDate]
				                            ),
				                            // tracks
				                            SELECTCOLUMNS (
				                                FILTER ( CaseTracks, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", CaseTracks[EndDate]
				                            ),
				                            // visits
				                            SELECTCOLUMNS (
				                                FILTER ( Treatments, RELATED ( PatientStays[PatientID] ) = pid ),
				                                "d", Treatments[LaborDate]
				                            ),
				                            // PLOS items
				                            SELECTCOLUMNS (
				                                FILTER ( PatientLevelOptionalServices_Instance, RELATED ( Patients[PatientID] ) = pid ),
				                                "d", PatientLevelOptionalServices_Instance[CreatedDate]
				                            ),
				                            // screens (PatientScreens)
				                            SELECTCOLUMNS (
				                                FILTER ( PatientScreens, PatientScreens[Resolved PatientID] = pid ),
				                                "d", PatientScreens[DateCompleted]
				                            )
				                        ),
				                        [d]
				                    )
				                RETURN
				                    COALESCE (
				                        PatientStays[DischargeDate],
				                        maxOtherDate + 1,
				                        PatientStays[AdmitDate] + 1
				                    )
				        ),
				
				        //---------------------------------------
				        // CASES (StayCases -> PatientStays, DischargeDestination via DischargedTo_ID)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            StayCases,
				            "PatientID",  RELATED ( PatientStays[PatientID] ),
				            "ItemID",     StayCases[PatientCase_ID],
				            "EventType",  "Case",
				            "LaneGroup",  "05|Case",
				            "Lane",       "05|Case",
				            "Item",       "Case",
				            "Detail",     RELATED ( DischargeDestination[Descrip] ),
				            "AdmitLevel", [Admit Level],
				            "DischargeLevel", [Discharge Level],
				            "Start",      StayCases[TherapyStartDate],
				            "End",
				                VAR endDate = StayCases[TherapyEndDate]
				                VAR startDate = StayCases[TherapyStartDate]
				                VAR todayDate = TODAY ()
				                RETURN
				                    COALESCE (
				                        endDate,
				                        IF ( startDate >= todayDate, startDate + 1, todayDate )
				                    )
				        ),
				
				        //---------------------------------------
				        // DISCHARGE DESTINATION (point event at case end; Detail blank when not discharged)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            FILTER ( StayCases, NOT ( ISBLANK ( StayCases[TherapyEndDate] ) ) ),
				            "PatientID",  RELATED ( PatientStays[PatientID] ),
				            "ItemID",     StayCases[PatientCase_ID],
				            "EventType",  "Discharge",
				            "LaneGroup",  "05|Discharge",
				            "Lane",       "05|Discharge",
				            "Item",       "Discharge",
				            "Detail",     RELATED ( DischargeDestination[Descrip] ),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      StayCases[TherapyEndDate],
				            "End",        StayCases[TherapyEndDate]
				        ),
				
				        //---------------------------------------
				        // TRACKS (separate lanes per discipline)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            CaseTracks,
				            "PatientID",  RELATED ( PatientStays[PatientID] ),
				            "ItemID",     CaseTracks[TxTrack_ID],
				            "EventType",  "Track",
				            "LaneGroup",  "06|Track",
				            "Lane",       "06|Track|" & RELATED ( Disciplines[Discipline] ),
				            "Item",       "Track",
				            "Detail",     RELATED ( Disciplines[Discipline] ),
				            "AdmitLevel", [Admit Level],
				            "DischargeLevel", [Discharge Level],
				            "Start",      CaseTracks[StartDate],
				            "End",
				                VAR endDate = CaseTracks[EndDate]
				                VAR startDate = CaseTracks[StartDate]
				                VAR todayDate = TODAY ()
				                RETURN
				                    COALESCE (
				                        endDate,
				                        IF ( startDate >= todayDate, startDate + 1, todayDate )
				                    )
				        ),
				
				        //---------------------------------------
				        // VISITS (same lane as the discipline Track)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            Treatments,
				            "PatientID",  RELATED ( PatientStays[PatientID] ),
				            "ItemID",     Treatments[SessionId],
				            "EventType",  "Visit",
				            "LaneGroup",  "06|Track",
				            "Lane",       "06|Track|" & RELATED ( Disciplines[Discipline] ),
				            "Item",       "Track",
				            "Detail",     RELATED ( Disciplines[Discipline] ),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      Treatments[LaborDate],
				            "End",        Treatments[LaborDate]
				        ),
				
				        //---------------------------------------
				        // PLOS - Nursing Restorative (point events)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            FILTER (
				                PatientLevelOptionalServices_Instance,
				                RELATED ( PatientLevelOptionalServices_Service[Category] ) = "Nursing Restorative"
				            ),
				            "PatientID",  RELATED ( Patients[PatientID] ),
				            "ItemID",     PatientLevelOptionalServices_Instance[Service_ID],
				            "EventType",  "PLOS",
				            "LaneGroup",  "07|PLOS",
				            "Lane",       "07|PLOS|Nursing Restorative",
				            "Item",       "PLOS",
				            "Detail",     BLANK (),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      PatientLevelOptionalServices_Instance[CreatedDate],
				            "End",        PatientLevelOptionalServices_Instance[CreatedDate]
				        ),
				
				        //---------------------------------------
				        // PLOS - Rehab Tech (point events)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            FILTER (
				                PatientLevelOptionalServices_Instance,
				                RELATED ( PatientLevelOptionalServices_Service[Category] ) = "Rehab Tech"
				            ),
				            "PatientID",  RELATED ( Patients[PatientID] ),
				            "ItemID",     PatientLevelOptionalServices_Instance[Service_ID],
				            "EventType",  "PLOS",
				            "LaneGroup",  "07|PLOS",
				            "Lane",       "07|PLOS|Rehab Tech",
				            "Item",       "PLOS",
				            "Detail",     BLANK (),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      PatientLevelOptionalServices_Instance[CreatedDate],
				            "End",        PatientLevelOptionalServices_Instance[CreatedDate]
				        ),
				
				        //---------------------------------------
				        // Screens: PatientScreens (DateCompleted) + PLOS (CreatedDate)
				        //---------------------------------------
				        UNION (
				            SELECTCOLUMNS (
				                FILTER ( PatientScreens, NOT ( ISBLANK ( PatientScreens[DateCompleted] ) ) ),
				                "PatientID",  PatientScreens[Resolved PatientID],
				                "ItemID",     PatientScreens[Id],
				                "EventType",  "PLOS",
				                "LaneGroup",  "07|PLOS",
				                "Lane",       "07|PLOS|Screens",
				                "Item",       "PLOS",
				                "Detail",     BLANK (),
				                "AdmitLevel", BLANK (),
				                "DischargeLevel", BLANK (),
				                "Start",      PatientScreens[DateCompleted],
				                "End",        PatientScreens[DateCompleted]
				            ),
				            SELECTCOLUMNS (
				                FILTER (
				                    PatientLevelOptionalServices_Instance,
				                    RELATED ( PatientLevelOptionalServices_Service[Category] ) = "Screens"
				                ),
				                "PatientID",  RELATED ( Patients[PatientID] ),
				                "ItemID",     PatientLevelOptionalServices_Instance[Service_ID],
				                "EventType",  "PLOS",
				                "LaneGroup",  "07|PLOS",
				                "Lane",       "07|PLOS|Screens",
				                "Item",       "PLOS",
				                "Detail",     BLANK (),
				                "AdmitLevel", BLANK (),
				                "DischargeLevel", BLANK (),
				                "Start",      PatientLevelOptionalServices_Instance[CreatedDate],
				                "End",        PatientLevelOptionalServices_Instance[CreatedDate]
				            )
				        ),
				
				        //---------------------------------------
				        // PLOS - Wellness (point events)
				        //---------------------------------------
				        SELECTCOLUMNS (
				            FILTER (
				                PatientLevelOptionalServices_Instance,
				                RELATED ( PatientLevelOptionalServices_Service[Category] ) = "Wellness"
				            ),
				            "PatientID",  RELATED ( Patients[PatientID] ),
				            "ItemID",     PatientLevelOptionalServices_Instance[Service_ID],
				            "EventType",  "PLOS",
				            "LaneGroup",  "07|PLOS",
				            "Lane",       "07|PLOS|Wellness",
				            "Item",       "PLOS",
				            "Detail",     BLANK (),
				            "AdmitLevel", BLANK (),
				            "DischargeLevel", BLANK (),
				            "Start",      PatientLevelOptionalServices_Instance[CreatedDate],
				            "End",        PatientLevelOptionalServices_Instance[CreatedDate]
				        )
				    ),
				    NOT ( ISBLANK ( [PatientID] ) )
				    )
				VAR filtered = FILTER ( base, [End] >= cutoff )
				RETURN
				    SELECTCOLUMNS (
				        filtered,
				        "PatientID", [PatientID],
				        "ItemID", [ItemID],
				        "EventType", [EventType],
				        "LaneGroup", [LaneGroup],
				        "Lane", [Lane],
				        "Item", [Item],
				        "Detail", [Detail],
				        "AdmitLevel", [AdmitLevel],
				        "DischargeLevel", [DischargeLevel],
				        "Start", IF ( [Start] < cutoff, cutoff, [Start] ),
				        "End", [End]
				    )
				
				```

	annotation PBI_Id = 8d7d386739aa464c9ee1ada423d75407


	measure 'Rehosp Numerator' =
			
			CALCULATE(
			    [Total Cases],
			    DischargeDestination[Setting]="Hospital"
			)
		formatString: #,0
		displayFolder: Discharge Destination
		lineageTag: 37f26861-54c1-4227-925e-6a51a308d657

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Min Level to Go Home' = .7
		lineageTag: 28de03ef-77ac-4449-961e-74e6898953f6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Minutes per Discipline per Week' =
			
			AVERAGEX(
			    StayCases,
			    DIVIDE(
			        DIVIDE(
			            [Total Minutes],
			            [Total Days]
			        )*7,
			        [Total Disciplines Unique]
			    )
			)
		displayFolder: Minutes
		lineageTag: 665da78d-22c3-4e62-ad0b-35e7e9d5a554

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Visits per Week' =
			
			DIVIDE(
			    [Total Visits],
			    [Total Days]
			)*7
		formatString: 0.00
		displayFolder: Visits
		lineageTag: 5396f10d-927c-45d4-a969-3bcd33632dd7

	measure 'ActiveFilters: Payer' =
			
			// IF(
			//     ISFILTERED('Payer Buckets'[Payer Categorization]),
			//     CONCATENATEX(VALUES('Payer Buckets'[Payer Categorization]),'Payer Buckets'[Payer Categorization],", "),
			//     IF(
			//         ISFILTERED('Payer Buckets'[Payer Grouping]),
			//         CONCATENATEX(VALUES('Payer Buckets'[Payer Grouping]),'Payer Buckets'[Payer Grouping],", "),
			//         "All"
			//     )
			// )
			
			IF(
			    ISFILTERED('Payer Buckets'[Payer Categorization]),
			    CONCATENATEX(VALUES('Payer Buckets'[Payer Categorization]),'Payer Buckets'[Payer Categorization],", "),
			    IF(
			        ISFILTERED('Payer Buckets'[Payer Grouping]),
			        CONCATENATEX(VALUES('Payer Buckets'[Payer Grouping]),'Payer Buckets'[Payer Grouping],", "),
			        "All"
			    )
			)
		lineageTag: e7eaa42f-8ad2-4237-a916-977ada3bd203

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Discharge Destination' = ```
			
			// IF(
			//     ISFILTERED(DischargeDestination[Setting]),
			//     CONCATENATEX(VALUES(DischargeDestination[Setting]),DischargeDestination[Setting],", "),
			//     IF(
			//         ISFILTERED(DischargeDestination[Group]),
			//         CONCATENATEX(VALUES(DischargeDestination[Group]),DischargeDestination[Group],", "),
			//         "All"
			//     )
			// )
			
			var filteredExpected = 
			IF(
			    ISFILTERED(StayCases[Expected Discharge Destination]),
			    "Expected: "&CONCATENATEX(VALUES(StayCases[Expected Discharge Destination]),StayCases[Expected Discharge Destination],", ")
			)
			
			var filteredActual = 
			IF(
			    ISFILTERED(DischargeDestination[Setting]),
			    "Actual: "&CONCATENATEX(VALUES(DischargeDestination[Setting]),DischargeDestination[Setting],", "),
			    IF(
			        ISFILTERED(DischargeDestination[Group]),
			        "Actual: "&CONCATENATEX(VALUES(DischargeDestination[Group]),DischargeDestination[Group],", ")
			    )
			)
			
			var newline = UNICHAR(13)&UNICHAR(10)
			VAR multiline = REPT(newline,2)
			var concatTable = FILTER({filteredExpected, filteredActual}, NOT(ISBLANK([Value])))
			// return concatTable
			return COALESCE(CONCATENATEX(concatTable,[Value],newline),"All")
			```
		lineageTag: 30ff543f-1b0f-408a-ab59-b663870d42c8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Diagnosis' = ```
			
			// IF(
			//     ISFILTERED(DX_Cases[L4]),
			//     CONCATENATEX(VALUES(DX_Cases[L4]),DX_Cases[L4],", "),
			//     IF(
			//         ISFILTERED(DX_Cases[L3]),
			//         CONCATENATEX(VALUES(DX_Cases[L3]),DX_Cases[L3],", "),
			//         IF(
			//             ISFILTERED(DX_Cases[L2]),
			//             CONCATENATEX(VALUES(DX_Cases[L2]),DX_Cases[L2],", "),
			//             IF(
			//                 ISFILTERED(DX_Cases[L1]),
			//                 CONCATENATEX(VALUES(DX_Cases[L1]),DX_Cases[L1],", "),
			//                 "All"
			//             )
			//         )
			//     )
			// )
			
			var L4filter = ISFILTERED(DX_Cases[L4])
			var L3filter = ISFILTERED(DX_Cases[L3])
			var L2filter = ISFILTERED(DX_Cases[L2])
			var L1filter = ISFILTERED(DX_Cases[L1])
			var primary = ISFILTERED(DX_Cases[Type])
			var specificity = SWITCH(TRUE(),L4filter,4,L3filter,3,L2filter,2,L1filter,1,0)
			var note = 
			    SWITCH(
			        specificity,
			        4,CONCATENATEX(VALUES(DX_Cases[L4]),DX_Cases[L4],", "),
			        3,CONCATENATEX(VALUES(DX_Cases[L3]),DX_Cases[L3],", "),
			        2,CONCATENATEX(VALUES(DX_Cases[L2]),DX_Cases[L2],", "),
			        1,CONCATENATEX(VALUES(DX_Cases[L1]),DX_Cases[L1],", "),
			        "All"
			    )
			return note
			```
		lineageTag: e76bd4fb-6400-43f9-82a2-9673e4444f9b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Discharge Type' =
			
			IF(
			    ISFILTERED(DischargeDestination[Type]),
			    CONCATENATEX(VALUES(DischargeDestination[Type]),DischargeDestination[Type],", "),
			    "All"
			)
		lineageTag: 90eea763-f824-42ed-bc64-e9140881e115

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: Place of Service' =
			
			IF(
			    ISFILTERED(IntakeSources[Name]),
			    CONCATENATEX(VALUES(IntakeSources[Name]),IntakeSources[Name],", "),
			    IF(
			        ISFILTERED(IntakeSources[SourceType]),
			        CONCATENATEX(VALUES(IntakeSources[SourceType]),IntakeSources[SourceType],", "),
			        "All"
			    )
			)
		lineageTag: 767eebd5-a157-4979-8d5a-8478900b3684

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ActiveFilters: All' = ```
			
			var newline = UNICHAR(13)&UNICHAR(10)
			var multiline = REPT(newline,2)
			
			var payer = 
			IF(ISFILTERED('Payer Buckets'[Payer Categorization]) || ISFILTERED('Payer Buckets'[Payer Grouping]),"Payer:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED('Payer Buckets'[Payer Categorization]),CONCATENATEX(VALUES('Payer Buckets'[PCLabel]),'Payer Buckets'[PCLabel],", "),
			    ISFILTERED('Payer Buckets'[Payer Grouping]),CONCATENATEX(VALUES('Payer Buckets'[PGLabel]),'Payer Buckets'[PGLabel],", ")
			))
			
			var agerange = 
			IF(ISFILTERED(StayCases[Age Range]),"Age Range:"&newline&
			CONCATENATEX(VALUES(StayCases[Age Range]),StayCases[Age Range],", ")
			)
			
			var diagnosis = 
			IF(NOT(ISFILTERED(DX_Cases[L1]) || ISFILTERED(DX_Cases[L2]) || ISFILTERED(DX_Cases[L3]) || ISFILTERED(DX_Cases[L4])),BLANK(),
			IF(ISFILTERED(DX_Cases[Type]),SELECTEDVALUE(DX_Cases[Type])&" ")&
			"Diagnosis:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DX_Cases[L4]),CONCATENATEX(VALUES(DX_Cases[L4]),DX_Cases[L4],", "),
			    ISFILTERED(DX_Cases[L3]),CONCATENATEX(VALUES(DX_Cases[L3]),DX_Cases[L3],", "),
			    ISFILTERED(DX_Cases[L2]),CONCATENATEX(VALUES(DX_Cases[L2]),DX_Cases[L2],", "),
			    ISFILTERED(DX_Cases[L1]),CONCATENATEX(VALUES(DX_Cases[L1]),DX_Cases[L1],", ")
			))
			
			var DCtype = 
			IF(ISFILTERED(DischargeDestination[Type]),"D/C Type"&newline&
			CONCATENATEX(VALUES(DischargeDestination[Type]),DischargeDestination[Type],", ")
			)
			
			var DCdest = 
			IF(ISFILTERED(DischargeDestination[Setting]) || ISFILTERED(DischargeDestination[Group]),"D/C Destination"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(DischargeDestination[Setting]),CONCATENATEX(VALUES(DischargeDestination[Setting]),DischargeDestination[Setting],", "),
			    ISFILTERED(DischargeDestination[Group]),CONCATENATEX(VALUES(DischargeDestination[Group]),DischargeDestination[Group],", ")
			))
			
			var DCexpected = 
			IF(ISFILTERED(StayCases[Expected Discharge Destination]),"Expected D/C Destination:"&newline&
			CONCATENATEX(VALUES(StayCases[Expected Discharge Destination]),StayCases[Expected Discharge Destination],", ")
			)
			
			var placeofservice = 
			IF(ISFILTERED(IntakeSources[Name]) || ISFILTERED(IntakeSources[SourceType]),"Place of Service:"&newline&
			SWITCH(
			    TRUE(),
			    ISFILTERED(IntakeSources[Name]),CONCATENATEX(VALUES(IntakeSources[Name]),IntakeSources[Name],", "),
			    ISFILTERED(IntakeSources[SourceType]),CONCATENATEX(VALUES(IntakeSources[SourceType]),IntakeSources[SourceType],", ")
			))
			
			var concatTable = FILTER({payer,agerange,diagnosis,DCtype,DCdest,DCexpected,placeofservice},NOT(ISBLANK([Value])))
			
			return COALESCE(CONCATENATEX(concatTable,[Value],multiline),"None")

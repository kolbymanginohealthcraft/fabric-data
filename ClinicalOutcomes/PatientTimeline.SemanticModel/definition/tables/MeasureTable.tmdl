		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Aquatic
		lineageTag: a7ed64f1-2aab-4fcf-9d1a-c6095f9ca25d

	measure '% Visits Aquatic' =
			
			DIVIDE(
			    [Total Visits Aquatic],

			)
		formatString: #,0
		displayFolder: Aquatic
		lineageTag: 09f984a6-c6d0-4514-b19d-e5238dd3bdf0

	measure 'Gap: Stay to Case' =
			
			AVERAGEX(
			    StayCases,
			    DATEDIFF(RELATED(PatientStays[AdmitDate]),StayCases[TherapyStartDate],DAY)
			)
		displayFolder: Misc
		lineageTag: d4ef0e71-eaa1-4cf0-9a21-bd5dbe92042c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Day 1 Evals' =
			
			var numerator = CALCULATE([Total Cases],FILTER(StayCases,[Gap: Stay to Case]=0))
			var denominator = [Total Cases]
			return DIVIDE(numerator,denominator)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Misc
		lineageTag: fdf9e2eb-60ee-439a-ae84-1987cf722c0c

	measure 'Disciplines Involved' =
			
			var VisitsPT = IF(CALCULATE([Total Visits],Disciplines[Discipline]="PT")>0,"PT")
			var VisitsOT = IF(CALCULATE([Total Visits],Disciplines[Discipline]="OT")>0,"OT")
			var VisitsST = IF(CALCULATE([Total Visits],Disciplines[Discipline]="ST")>0,"ST")
			var ValuesTable = FILTER({VisitsPT, VisitsOT, VisitsST}, NOT(ISBLANK([Value])))
			var ValuesList = CONCATENATEX(ValuesTable,[Value],"/")
			return ValuesList
		displayFolder: Misc
		lineageTag: 35288c9d-f2a5-4f80-880b-b642bb83bd14

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "ConcatenateValues"
				}

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Days' =
			
			// SUMX (
			//     VALUES(StayCases[PatientCase_ID]),
			//     CALCULATE (
			//         COUNTROWS (
			//             FILTER (
			//                 ALL('Calendar'),
			//                 COUNTROWS (
			//                     FILTER (
			//                         CaseTracks,
			//                         CaseTracks[PatientCase_ID] = MAX(StayCases[PatientCase_ID])
			//                         && 'Calendar'[Date] >= CaseTracks[StartDate]
			//                         && 'Calendar'[Date] <= CaseTracks[EndDate]
			//                     )
			//                 ) > 0
			//             )
			//         )
			//     )
			// )
			
			SUM(StayCases[UniqueDays])
			
			// SUMX(
			//     VALUES(StayCases[PatientCase_ID]),
			//     [Total Unique CaseTrackDays]
			// )
		formatString: #,0
		displayFolder: Misc
		lineageTag: e577077a-991e-4e07-aa63-8f4d448220d1

	measure 'Total Disciplines Unique' =
			
			CALCULATE(
			    DISTINCTCOUNT(Disciplines[Discipline]),
			    FILTER(
			        CaseTracks,
			        [Total Visits]>0
			    )
			)
		formatString: 0
		displayFolder: Misc
		lineageTag: 30637786-6920-4722-9f4a-0c59fc87f64c


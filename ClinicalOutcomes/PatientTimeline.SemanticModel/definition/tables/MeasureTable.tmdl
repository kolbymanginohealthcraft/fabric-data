			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Aquatic
		lineageTag: ee74d04f-9aa0-4fbb-b5ff-dd154bd485c9

	measure 'Total Units Aquatic' =
			
			CALCULATE(
			    [Total Units],
			    Service[Specialty]="Aquatic"
			)
		formatString: #,0
		displayFolder: Aquatic
		lineageTag: 20a478b4-2a06-4bb9-995d-a549db1d0537

	measure 'Total Visits Aquatic' =
			

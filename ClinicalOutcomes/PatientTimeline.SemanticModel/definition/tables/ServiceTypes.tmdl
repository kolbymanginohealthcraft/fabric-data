	partition ServiceTypes = calculated
		mode: import
		source = ```
				
				DATATABLE (
				    "SortOrder", INTEGER,
				    "ServiceType", STRING,
				    {
				        { 1, "Case" },
				        { 2, "Track - PT" },
				        { 3, "Track - OT" },
				        { 4, "Track - ST" },
				        { 5, "Additional Services" },
				        { 6, "Nursing Restorative" },
				        { 7, "Rehab Tech" },
				        { 8, "Screens" },
				        { 9, "Electronic Screens" },
				        { 10, "Wellness" },
				        { 11, "Any Service" },
				        { 12, "No Service" },
				        { 13, "Total Patients" },
				        { 14, "% Touched (Any Service)" },
				        { 15, "% On Caseload" },
				        { 16, "% On Additional Services" }
				    }
				)
				
				```

	annotation PBI_Id = 0c8c52d1ff1645419346dad01ef3f12a


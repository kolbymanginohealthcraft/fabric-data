model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Patient

	annotation PBI_QueryGroupOrder = 3

queryGroup Payer

	annotation PBI_QueryGroupOrder = 4

queryGroup Outcomes

	annotation PBI_QueryGroupOrder = 5

queryGroup Visits

	annotation PBI_QueryGroupOrder = 6

queryGroup Procedures

	annotation PBI_QueryGroupOrder = 7

queryGroup Discharge

	annotation PBI_QueryGroupOrder = 8

queryGroup Diagnoses

	annotation PBI_QueryGroupOrder = 9

queryGroup Places

	annotation PBI_QueryGroupOrder = 0

queryGroup People

	annotation PBI_QueryGroupOrder = 2

queryGroup Management

	annotation PBI_QueryGroupOrder = 9

queryGroup FabricTables

	annotation PBI_QueryGroupOrder = 10

annotation PBI_QueryOrder = ["Patients","PatientStays","StayCases","CaseTracks","vw_PatientPayers","Payers","DischargeDestination","Documents","Facility","Treatments","TreatmentsDetails","Disciplines","Service","Diagnosis","DiagnosisCode","MeasureTable","IntakeSources","vw_UpnFacilityAccess","ExpectedDischargeDestination","EDD","PatientScreens","PatientLevelOptionalServices_Instance","PatientLevelOptionalServices_Service","CohortAnchorDate","_CohortAnchorDateText","_SilverSource","_PreImpl","_NetHealthBronze","_RoxAegis","_QualifyingCaseIdsSql","_QualifyingCases","_QualifyingTracks","_QualifyingStays","_QualifyingCaseIdList","dbo_vw_PatientStays","dbo_vw_StayCases","dbo_vw_CaseTracks","dbo vw_AllEvalsAndDischargesLight","excelOutcomesCrosswalk","dbo vw_AllEvalsAndDischargesLight_Items","excelOutcomesCustomScales","dbo_vw_Treatments","dbo_vw_Diagnosis","excel_Employee_FTE_status_vs_patient_outcomes_WD_Roster","dbo_vw_UpnFacilityAccess","_AegisPatient"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table Patients
ref table PatientStays
ref table StayCases
ref table CaseTracks
ref table vw_PatientPayers
ref table Payers
ref table Documents
ref table DischargeDestination
ref table Calendar
ref table Treatments
ref table TreatmentsDetails
ref table Disciplines
ref table Service
ref table Diagnosis
ref table DiagnosisCode
ref table MeasureTable
ref table vw_UpnFacilityAccess
ref table ContextTable
ref table 'Payer Buckets'

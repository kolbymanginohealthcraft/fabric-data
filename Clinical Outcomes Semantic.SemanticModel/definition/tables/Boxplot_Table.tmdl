	measure Boxplot_Percentile = ```
			
			var myvalue = 
			    SWITCH(
			        MAX('Boxplot_Table'[_BoxplotMeasure]),
			        "Minutes per Case",[Minutes per Case],
			        "Visits per Case",[Visits per Case],
			        "Minutes per Week",[Minutes per Week],
			        "Visits per Week",[Visits per Discipline per Week],
			        "Minutes per Visit",[Minutes per Visit],
			        "Units per Visit",[Units per Visit (pt/ot)],
			        "ALOS",[ALOS],
			        // "Number of Disciplines",[Avg Number of Disciplines],
			        BLANK()
			    )
			
			
			return
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(
			            FILTER(
			                StayCases,
			                    SWITCH(
			                        MAX('Boxplot_Table'[_BoxplotMeasure]),
			                        "Minutes per Case",[Minutes per Case],
			                        "Visits per Case",[Visits per Case],
			                        "Minutes per Week",[Minutes per Week],
			                        "Visits per Week",[Visits per Discipline per Week],
			                        "Minutes per Visit",[Minutes per Visit],
			                        "Units per Visit",[Units per Visit (pt/ot)],
			                        "ALOS",[ALOS],
			                        // "Number of Disciplines",[Avg Number of Disciplines],
			                        BLANK()
			                    )
			                <myvalue
			            )
			        ),
			        //main filters
			        ALL('Aegis Contract'),
			        ALL(StayCases[PatientCase_ID]),
			        ALL(vw_UpnFacilityAccess),
			        ALL(Perspectives),
			        ALL(Employees),
			
			        //override filters for state, type, and chain
			        SWITCH(TRUE(),ISFILTERED('Override State'[BillingState]),Account[BillingState] IN VALUES('Override State'[BillingState]),TRUE()),
			        SWITCH(TRUE(),ISFILTERED('Override Type'[Type]),Account[Type] IN VALUES('Override Type'[Type]),TRUE()),
			        SWITCH(TRUE(),ISFILTERED('Override Chain'[Name]),Chain[Name] IN VALUES('Override Chain'[Name]),TRUE())
			
			        //override filter for payer
			        // SWITCH(
			        //     TRUE(),
			        //     ISFILTERED('Override Payer'[Payer Grouping]),'Payer Buckets'[Payer Grouping] IN VALUES('Override Payer'[Payer Grouping]),
			        //     ISFILTERED('Payer Buckets'[Payer Categorization]),'Payer Buckets'[Payer Categorization] IN VALUES('Payer Buckets'[Payer Categorization]),
			        //     ISFILTERED('Payer Buckets'[Payer Grouping]),'Payer Buckets'[Payer Grouping] IN VALUES('Payer Buckets'[Payer Grouping]),
			        //     TRUE()
			        // )
			    ),
			    [Total Cases BM]
			)
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: daa9a8d7-75e3-4ffd-baa3-e2c463b5f432


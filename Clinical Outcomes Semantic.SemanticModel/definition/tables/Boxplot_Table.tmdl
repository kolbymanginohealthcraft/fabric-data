	measure 'Boxplot SVG 2' = ```
			
			
			var canvasWidth = 774
			var canvasHeight = 70
			
			var endLinePad_x = .12 //left and right padding for end lines (10th and 90th percentiles)
			var endLinePad_y = .33 //top and bottom padding for end lines (10th and 90th percentiles)
			var valueLine_y = .1 //top and bottom padding for value line (provider)
			var endLabelSize = 25
			var valueLabelSize = endLabelSize*1.25
			var endLabel_x = .03 //left and right padding for end labels (10th and 90th percentiles)
			var endLabel_y = (endLabelSize/100)/2+.5
			var valueLabel_y = .5-((.5-valueLabelSize/100)/2) //where the value label sits (prev .45)
			var averageLabel_y = .5+((.5-endLabelSize/100)/2)+endLabelSize/100 //where the average label sits (prev .80)
			var box_y = .25 //top and bottom padding for the box
			
			return
			
			//prefix
			"data:image/svg+xml;utf8,<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//box
			"<rect 
			    x="""&(([Boxplot_p25]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    y="""&box_y*canvasHeight&""" 
			    width="""&(([Boxplot_p75]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth-(([Boxplot_p25]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    height="""&(1-(2*box_y))*canvasHeight&""" 
			    fill=""#3DB3E3"" 
			    fill-opacity=""0.25""
			    stroke=""#3DB3E3""
			    stroke-opacity=""0.10""
			/>"&
			
			//left end line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&endLinePad_x*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke=""#3DB3E3"" 
			    stroke-width=""1.5""
			/>"&
			
			//right end line
			"<line 
			    x1="""&(1-endLinePad_x)*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&(1-endLinePad_y)*canvasHeight&""" 
			    stroke=""#3DB3E3"" 
			    stroke-width=""1.5""
			/>"&
			
			//value line
			"<line 
			    x1="""&(([Boxplot_Value]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    y1="""&valueLine_y*canvasHeight&""" 
			    x2="""&(([Boxplot_Value]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    "&
			        IF([Report Scope]="Filtered","y2="""&.5*canvasHeight&""" ","y2="""&(1-valueLine_y)*canvasHeight&""" ")
			    &"
			    stroke=""#0C436A"" 
			    stroke-width=""5""
			/>"&
			
			//average line
			IF([Report Scope]="Filtered",
			"<line 
			    x1="""&(([Boxplot_Benchmark]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    y1="""&.5*canvasHeight&""" 
			    x2="""&(([Boxplot_Benchmark]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth&""" 
			    y2="""&(1-valueLine_y)*canvasHeight&""" 
			    stroke=""#3DB3E3"" 
			    stroke-width=""3""
			/>")&
			
			//span line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&.50*canvasHeight&""" 
			    x2="""&(1-endLinePad_x)*canvasWidth&""" 
			    y2="""&.50*canvasHeight&""" 
			    stroke=""#3DB3E3""
			    stroke-width=""1.5""
			/>"&
			
			//left label
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".75"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&endLabel_x*canvasWidth&""" 
			        y="""&endLabel_y*canvasHeight&""">"
			        &
			        ""&
			        // FORMAT([Boxplot_p10],"###")
			        SWITCH(
			            TRUE(),
			            [Boxplot_Value]<10,FORMAT([Boxplot_p10],"0.00"),
			            [Boxplot_Value]<100,FORMAT([Boxplot_p10],"0.0"),
			            FORMAT([Boxplot_p10],"#,###")
			        )
			        &""
			    &"</tspan>
			</text>"&
			
			//right label
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".75"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&.91*canvasWidth&""" 
			        y="""&endLabel_y*canvasHeight&""">"
			        &
			        ""&
			        // FORMAT([Boxplot_p90],"#,###")
			        SWITCH(
			            TRUE(),
			            [Boxplot_Value]<10,FORMAT([Boxplot_p90],"0.00"),
			            [Boxplot_Value]<100,FORMAT([Boxplot_p90],"0.0"),
			            FORMAT([Boxplot_p90],"#,###")
			        )
			        &""
			    &"</tspan>
			</text>"&
			
			//value label
			"<text 
			    fill=""#0C436A"" fill-opacity="".90"" font-family=""Calibri"" font-size="""&valueLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&(([Boxplot_Value]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth*1.04&""" 
			        y="""&valueLabel_y*canvasHeight&""">"
			        &
			        ""&
			        SWITCH(
			            TRUE(),
			            [Boxplot_Value]<10,FORMAT([Boxplot_Value],"0.00"),
			            [Boxplot_Value]<100,FORMAT([Boxplot_Value],"0.0"),
			            FORMAT([Boxplot_Value],"#,###")
			        )
			        &""
			    &"</tspan>
			</text>"&
			
			
			//average label
			IF([Report Scope]="Filtered",
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".90"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&(([Boxplot_Benchmark]-[Boxplot_p05])/([Boxplot_p95]-[Boxplot_p05]))*canvasWidth*1.04&""" 
			        y="""&averageLabel_y*canvasHeight&""">"
			        &
			        ""&
			        SWITCH(
			            TRUE(),
			            [Boxplot_Value]<10,FORMAT([Boxplot_Benchmark],"0.00"),
			            [Boxplot_Value]<100,FORMAT([Boxplot_Benchmark],"0.0"),
			            FORMAT([Boxplot_Benchmark],"#,###")
			        )
			        &""
			    &"</tspan>
			</text>")&
			
			//suffix
			"</svg>"
			```

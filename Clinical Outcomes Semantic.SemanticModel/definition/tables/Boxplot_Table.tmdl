	measure 'Boxplot SVG 3' = ```
			
			
			var canvasWidth = 750 //774
			var canvasHeight = 70
			
			var endLinePad_x = .12 //left and right padding for end lines (10th and 90th percentiles)
			var endLinePad_y = .33 //top and bottom padding for end lines (10th and 90th percentiles)
			var endLinePad_xComp = 1-endLinePad_x
			var endLinePad_yComp = 1-endLinePad_y
			
			var valueLine_y = .1 //top and bottom padding for value line (provider)
			var valueLine_yComp = 1-valueLine_y
			
			var endLabelSize = 25
			var valueLabelSize = endLabelSize*1.25
			var middleLabelSize = endLabelSize*.8
			
			var endLabel_x = .03 //left and right padding for end labels (10th and 90th percentiles)
			var endLabel_y = (endLabelSize/100)/2+.5
			
			var valueLabel_y = .5-((.5-valueLabelSize/100)/2) //where the value label sits (prev .45)
			var averageLabel_y = .5+((.5-endLabelSize/100)/2)+endLabelSize/100 //where the average label sits (prev .80)
			
			var box_y = .25 //top and bottom padding for the box
			
			var p05 = Boxplot_Table[Boxplot_p05]
			var p10 = Boxplot_Table[Boxplot_p10] //left end line
			var p25 = Boxplot_Table[Boxplot_p25] //box start
			var p75 = Boxplot_Table[Boxplot_p75] //box end
			var p90 = Boxplot_Table[Boxplot_p90] //right end line
			var p95 = Boxplot_Table[Boxplot_p95]
			var positionAdjustment = p95-p05 //for positioning within boxplot
			var boxadj25 = p25-p05
			var boxadj75 = p75-p05
			
			var bval = Boxplot_Table[Boxplot_Value]
			var bbench = Boxplot_Table[Boxplot_Benchmark]
			
			var bval_pos = SWITCH(TRUE(),bval<p05,p05,bval>p95,p95,bval)-p05
			var bbench_pos = bbench-p05
			
			var magnitudeFormatString = SWITCH(TRUE,bbench<10,"0.00",bbench<100,"0.0","#,###")
			
			return
			
			//prefix
			"data:image/svg+xml;utf8,<svg width="""&canvasWidth&""" height="""&canvasHeight&""" xmlns=""http://www.w3.org/2000/svg"">"&
			
			//box
			"<rect 
			    x="""&(boxadj25/positionAdjustment)*canvasWidth&""" 
			    y="""&box_y*canvasHeight&""" 
			    width="""&(boxadj75/positionAdjustment)*canvasWidth-(boxadj25/positionAdjustment)*canvasWidth&""" 
			    height="""&(1-(2*box_y))*canvasHeight&""" 
			    fill=""#3DB3E3"" fill-opacity=""0.25"" stroke=""#3DB3E3"" stroke-opacity=""0.10""
			/>"&
			
			//left end line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&endLinePad_x*canvasWidth&""" 
			    y2="""&endLinePad_yComp*canvasHeight&""" 
			    stroke=""#3DB3E3"" stroke-width=""1.5""
			/>"&
			
			//right end line
			"<line 
			    x1="""&endLinePad_xComp*canvasWidth&""" 
			    y1="""&endLinePad_y*canvasHeight&""" 
			    x2="""&endLinePad_xComp*canvasWidth&""" 
			    y2="""&endLinePad_yComp*canvasHeight&""" 
			    stroke=""#3DB3E3"" stroke-width=""1.5""
			/>"&
			
			//value line
			"<line 
			    x1="""&(bval_pos/positionAdjustment)*canvasWidth&""" 
			    y1="""&valueLine_y*canvasHeight&""" 
			    x2="""&(bval_pos/positionAdjustment)*canvasWidth&""" 
			    "&
			        IF([Report Scope]="Filtered","y2="""&.5*canvasHeight&""" ","y2="""&(valueLine_yComp)*canvasHeight&""" ")
			    &"
			    stroke=""#0C436A"" stroke-width=""5""
			/>"&
			
			//average line
			IF([Report Scope]="Filtered",
			"<line 
			    x1="""&(bbench_pos/positionAdjustment)*canvasWidth&""" 
			    y1="""&.5*canvasHeight&""" 
			    x2="""&(bbench_pos/positionAdjustment)*canvasWidth&""" 
			    y2="""&valueLine_yComp*canvasHeight&""" 
			    stroke=""#3DB3E3"" stroke-width=""3""
			/>")&
			
			//span line
			"<line 
			    x1="""&endLinePad_x*canvasWidth&""" 
			    y1="""&.50*canvasHeight&""" 
			    x2="""&endLinePad_xComp*canvasWidth&""" 
			    y2="""&.50*canvasHeight&""" 
			    stroke=""#3DB3E3"" stroke-width=""1.5""
			/>"&
			
			//left label
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".75"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&endLabel_x*canvasWidth&""" 
			        y="""&endLabel_y*canvasHeight&""">"
			        &
			        ""&
			        FORMAT(p10,magnitudeFormatString)
			        &""
			    &"</tspan>
			</text>"&
			
			//right label
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".75"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&.91*canvasWidth&""" 
			        y="""&endLabel_y*canvasHeight&""">"
			        &
			        ""&
			        FORMAT(p90,magnitudeFormatString)
			        &""
			    &"</tspan>
			</text>"&
			
			//value label
			"<text 
			    fill=""#0C436A"" fill-opacity="".90"" font-family=""Calibri"" font-size="""&valueLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&(bval_pos/positionAdjustment)*canvasWidth*1.04&""" 
			        y="""&valueLabel_y*canvasHeight&""">"
			        &
			        ""&
			        FORMAT(bval,magnitudeFormatString)
			        &""
			    &"</tspan>
			</text>"&
			
			//average label
			IF([Report Scope]="Filtered",
			"<text 
			    fill=""#3DB3E3"" fill-opacity="".90"" font-family=""Calibri"" font-size="""&endLabelSize&""" font-weight=""bold""
			>
			    <tspan 
			        x="""&(bbench_pos/positionAdjustment)*canvasWidth*1.04&""" 
			        y="""&averageLabel_y*canvasHeight&""">"
			        &
			        ""&
			        FORMAT(bbench,magnitudeFormatString)
			        &""
			    &"</tspan>
			</text>")&
			
			//suffix
			"</svg>"
			```

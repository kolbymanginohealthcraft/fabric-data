	measure Boxplot_p95 =
			
			var range = [Boxplot_p90]-[Boxplot_p10]
			var extendedrange = range/.8
			var incrementalrange = (extendedrange-range)/2
			var calc = [Boxplot_p90]+incrementalrange
			return calc

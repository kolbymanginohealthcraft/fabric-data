table PercentileTable
	lineageTag: 8e2bc395-76ca-4382-874c-74fb4b99c050

	calculationGroup
		precedence: 4

		calculationItem cases_p10 =
				
				VAR __Div = VALUES(VW_NHAegisFacilities[Division])   -- capture current Division selection
				RETURN
				CALCULATE(
				    PERCENTILEX.INC(
				        StayCases,
				        SELECTEDMEASURE(),
				        .1
				    ),
				    // reset almost everything
				    REMOVEFILTERS('Aegis Contract'),
				    REMOVEFILTERS(StayCases[PatientCase_ID]),
				    REMOVEFILTERS(vw_UpnFacilityAccess),
				    REMOVEFILTERS(Perspectives),
				    REMOVEFILTERS(Employees),
				
				    // keep Division if it was filtered (exactly as filtered)
				    KEEPFILTERS(__Div),
				
				    // override filters for state, type, and chain
				    SWITCH(
				        TRUE(),
				        ISFILTERED('Override State'[BillingState]),
				            Account[BillingState] IN VALUES('Override State'[BillingState]),
				        TRUE()
				    ),
				    SWITCH(
				        TRUE(),
				        ISFILTERED('Override Type'[Type]),
				            Account[Type] IN VALUES('Override Type'[Type]),
				        TRUE()
				    ),
				    SWITCH(
				        TRUE(),
				        ISFILTERED('Override Chain'[Name]),
				            Chain[Name] IN VALUES('Override Chain'[Name]),
				        TRUE()
				    )
				
				    // payer override block unchanged / optional
				)


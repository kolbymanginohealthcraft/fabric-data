		calculationItem sites_p90 =
				
				CALCULATE(
				    PERCENTILEX.INC(
				        Account,
				        SELECTEDMEASURE(),
				        .90
				    ),
				    //main filters
				    ALL('Aegis Contract'),
				    ALL(StayCases[PatientCase_ID]),
				    ALL(vw_UpnFacilityAccess),
				    ALL(Perspectives),
				    ALL(Employees),
				
				    //override filters for state, type, and chain
				    SWITCH(TRUE(),ISFILTERED('Override State'[BillingState]),Account[BillingState] IN VALUES('Override State'[BillingState]),TRUE()),
				    SWITCH(TRUE(),ISFILTERED('Override Type'[Type]),Account[Type] IN VALUES('Override Type'[Type]),TRUE()),

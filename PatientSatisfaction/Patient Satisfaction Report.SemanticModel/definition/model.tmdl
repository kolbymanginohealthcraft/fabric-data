model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Customer Data'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Survey Support'

	annotation PBI_QueryGroupOrder = 3

queryGroup Survey

	annotation PBI_QueryGroupOrder = 1

queryGroup Clinical

	annotation PBI_QueryGroupOrder = 3

annotation PBI_QueryOrder = ["Data","Surveys","Dictionary","Disciplines","Sentiments","Scoring","Respondent","Aegis Contract","VW_NHAegisFacilities","Account","Chain","vw_UpnFacilityAccess","ScoringType","Comments","CustomerGroups","Patients","PatientStays","StayCases","DischargeReason","DischargeDestination"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["CalcGroup","DevMode"]

ref table Surveys
ref table Sentiments
ref table Dictionary
ref table Scoring
ref table Calendar
ref table Disciplines
ref table Account
ref table Chain
ref table 'Aegis Contract'
ref table Respondent
ref table vw_UpnFacilityAccess
ref table ContextTable
ref table ScoringType
ref table Data
ref table Comments
ref table CustomerGroups
ref table StayCases
ref table PatientStays
ref table Patients
ref table DischargeReason
ref table VW_NHAegisFacilities
ref table DischargeDestination

ref cultureInfo en-US


table DischargeReason
	lineageTag: af548291-7c3b-4ed6-ad17-73bfb11dca98

	measure 'Reason Code' =
			
			IF(HASONEVALUE(DischargeReason[Lookup_ID]),
			    FIRSTNONBLANK(DischargeReason[Lookup_ID],1),
			    BLANK()
			)
		formatString: 0
		lineageTag: c3fcd53a-6657-467e-97d4-6f9ad9a69612

	column Lookup_ID
		dataType: int64
		formatString: 0

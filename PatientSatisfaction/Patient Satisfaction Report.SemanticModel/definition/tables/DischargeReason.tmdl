		sourceColumn: Descrip

		annotation SummarizationSetBy = Automatic

	column Type =
			
			// IF(
			//     DischargeReason[Lookup_ID] IN {466, 467, 469, 480, 1544, 1546, 1548, 1553, 1554},
			//     "Planned","Unplanned"
			// )
			
			// IF(
			//     DischargeReason[Lookup_ID] IN {468, 1545, 1543, 1552},
			//     "Unplanned","Planned"
			// )
			
			IF(DischargeReason[Lookup_ID] IN {464, 465, 468, 1506, 1545, 1543, 1547, 1549, 1550, 1551, 1552, 1555},"Unplanned",
			"Planned"
			)
		lineageTag: 23ecb3d6-69b8-4066-adfa-41fc1fb37586
		summarizeBy: none

		annotation SummarizationSetBy = Automatic


	partition Account = m
		mode: import
		queryGroup: 'Customer Data'
		source =
				let
				    Source = Salesforce.Data("https://login.salesforce.com/", [ApiVersion=48]),
				    Account1 = Source{[Name="Account"]}[Data],
				    #"Removed Other Columns" = Table.SelectColumns(Account1,{"Id", "Name", "Type", "BillingStreet", "BillingCity", "BillingState", "BillingPostalCode", "BillingLatitude", "BillingLongitude", "CCN__c"})
				in
				    #"Removed Other Columns"

	annotation PBI_ResultType = Table


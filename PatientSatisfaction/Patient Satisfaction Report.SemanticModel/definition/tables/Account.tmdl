table Account
	lineageTag: f7144510-3f4a-4585-aae0-fec818de15fb

	measure 'Total Facilities' =
			
			CALCULATE(
			    DISTINCTCOUNT(Account[Id]),
			    VW_NHAegisFacilities[IsValid],
			    FILTER(
			        Account,
			        [Total Respondents]>0 || [Total Planned Discharges]>0
			    )
			)
		formatString: 0
		lineageTag: aeb1aaef-6fcf-41f5-88e0-ce55ec520f34

	measure 'Customer Name' =
			
			// //if one account is selected
			// SELECTEDVALUE(Account[Name],
			
			// //if multiple accounts are selected
			// IF(ISFILTERED(CustomerGroups[Customer Group]),SELECTEDVALUE(CustomerGroups[Customer Group]),
			// IF(ISFILTERED(Chain[Name]),SELECTEDVALUE(Chain[Name]),
			// IF(ISFILTERED('Aegis Area'[Area_Ledger__c]),"Area "&SELECTEDVALUE('Aegis Area'[Area_Ledger__c]),
			// IF(ISFILTERED('Aegis District'[Name]),SELECTEDVALUE('Aegis District'[Name]),
			// IF(ISFILTERED('Aegis Region'[Name]),SELECTEDVALUE('Aegis Region'[Name]),
			// IF(ISFILTERED(Account[BillingState]),SELECTEDVALUE(Account[BillingState]),
			// IF([Total Facilities]=[Total Facilities BM],"Aegis Therapies",
			// "My Customers"
			// ))))))))
			
			// //shows number of facilities if more than one are selected
			// &IF([Total Facilities]>1," ("&[Total Facilities]&" facilities)")
			
			
			
			//if one account is selected
			SELECTEDVALUE(Account[Name],
			
			//if multiple accounts are selected
			IF(ISFILTERED(CustomerGroups[Customer Group]),SELECTEDVALUE(CustomerGroups[Customer Group]),
			IF(ISFILTERED(Chain[Name]),SELECTEDVALUE(Chain[Name]),
			IF(ISFILTERED(VW_NHAegisFacilities[Region]),"Region "&SELECTEDVALUE(VW_NHAegisFacilities[Region]),
			IF(ISFILTERED(VW_NHAegisFacilities[District]),"District "&SELECTEDVALUE(VW_NHAegisFacilities[District]),
			IF(ISFILTERED(VW_NHAegisFacilities[Division]),SELECTEDVALUE(VW_NHAegisFacilities[Division]),
			IF(ISFILTERED(Account[BillingState]),SELECTEDVALUE(Account[BillingState]),
			IF([Total Facilities]=[Total Facilities BM],"Aegis Therapies",
			"My Customers"
			))))))))
			
			//shows number of facilities if more than one are selected
			&IF([Total Facilities]>1," ("&[Total Facilities]&" facilities)")
		lineageTag: 8a420f27-ef2b-4f48-bfa1-ba48320910f7

	measure 'Total Facilities BM' =
			
			// CALCULATE(
			//     [Total Facilities],
			//     ALL(Surveys[SurveyID]),
			//     ALL(vw_UpnFacilityAccess)
			// )
			
			CALCULATE(
			    [Total Facilities],
			    ALL('Aegis Contract'),
			    ALL(Surveys[SurveyID]),
			    ALL(vw_UpnFacilityAccess)
			)
		formatString: 0
		lineageTag: 1cc26e10-b4fc-4c9c-b68e-e7c0f5be28c5

	measure 'Report Title' = IF(SELECTEDVALUE(VW_NHAegisFacilities[Division])="5500 (Direct Bill)","Client Satisfaction Report","Patient Satisfaction Report")
		lineageTag: a45b43fd-09eb-4b29-afe8-dfdb8ca2462f

	measure 'Total Facilities with AS' =
			
			CALCULATE(
			    [Total Facilities],
			    FILTER(
			        Account,
			        ISBLANK([Advocacy Score])=FALSE()
			    )
			)
		formatString: #,0
		lineageTag: 34415c1f-1c18-497d-9a21-bd8bc2e4ba01

	measure 'Total Facilities with NPS' =
			
			CALCULATE(
			    [Total Facilities],
			    FILTER(
			        Account,
			        ISBLANK([Net Promoter Score])=FALSE() && [Total Responses NPS]>=[NPS Threshold]
			    )
			)
		formatString: #,0
		lineageTag: 674766ba-09b2-4257-9b1e-1782ea5a347f

	measure '% Total Facilities with NPS' =
			
			DIVIDE(
			    [Total Facilities with NPS],
			    [Total Facilities]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 3a7a607a-9a04-4af9-bc5c-b95f9762de59

	measure 'Total Facilities Above Response Rate Baseline' =
			
			CALCULATE(
			    [Total Facilities],
			    FILTER(
			        Account,
			        [Respondents per Planned Discharge]>=[Respondents per Planned Discharge Baseline]
			    )
			)
		formatString: 0
		lineageTag: 2f57b463-6246-4552-aea3-60a567e0fc30

	measure '% Total Facilities Above Response Rate Baseline' =
			
			DIVIDE(
			    [Total Facilities Above Response Rate Baseline],
			    [Total Facilities]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 54b9d288-83c0-4160-b44d-42ef85d7ea00

	measure '% Total Facilities with AS' =
			
			DIVIDE(
			    [Total Facilities with AS],
			    [Total Facilities]
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: e5f70a15-26fb-4e27-935a-1823cd03b738

